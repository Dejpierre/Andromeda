            },
            "accordion_row_andromeda_6": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Sous combien de temps suis-je livré(e) ?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_andromeda_6": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Livraison en France sous 2 à 4 jours ouvrés. Livraison internationale sous 5 à 10 jours. Chaque commande est expédiée dans un emballage soigné, prête à offrir.</p>",
