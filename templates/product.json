            "custom_liquid_4CdyVR": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "disabled": true,
              "settings": {
                "custom_liquid": "{%- comment -%} ── Personnaliser ici ── {%- endcomment -%}\n{%- assign pb_label    = \"Solstice d'été\" -%}\n{%- assign pb_main     = \"Livraison offerte\" -%}\n{%- assign pb_sub      = \"Jusqu'au 21 juin minuit\" -%}\n{%- assign pb_end_date = \"2026-06-21T23:59:59+02:00\" -%}\n{%- assign pb_blur     = 4 -%}\n{%- assign pb_overlay  = 0.40 -%}\n{%- assign pb_bg_image = \"https://cdn.shopify.com/s/files/1/1000/9375/5727/files/background-soie.png?v=1781798658\" -%}\n{%- assign bid         = \"solstice\" -%}\n\n<div id=\"promo-banner-{{ bid }}\">\n  <div class=\"pb-inner-{{ bid }}\">\n\n    <div class=\"pb-bg-{{ bid }}\"></div>\n    <div class=\"pb-overlay-{{ bid }}\" style=\"background:rgba(235,220,200,{{ pb_overlay }});\"></div>\n\n    <div class=\"pb-content-{{ bid }}\">\n      <div class=\"pb-text-{{ bid }}\">\n        <div class=\"pb-text-top-{{ bid }}\">\n          <span class=\"pb-label-{{ bid }}\">{{ pb_label }}</span>\n          <span class=\"pb-sep-{{ bid }}\">—</span>\n          <span class=\"pb-sub-{{ bid }}\">{{ pb_sub }}</span>\n        </div>\n        <span class=\"pb-main-{{ bid }}\">{{ pb_main }}</span>\n      </div>\n      <div class=\"pb-cd-{{ bid }}\">\n        <div class=\"pb-cd-block-{{ bid }}\">\n          <span class=\"pb-cd-num-{{ bid }}\" id=\"cd-d-{{ bid }}\">--</span>\n          <span class=\"pb-cd-lbl-{{ bid }}\">Jours</span>\n        </div>\n        <span class=\"pb-cd-sep-{{ bid }}\">|</span>\n        <div class=\"pb-cd-block-{{ bid }}\">\n          <span class=\"pb-cd-num-{{ bid }}\" id=\"cd-h-{{ bid }}\">--</span>\n          <span class=\"pb-cd-lbl-{{ bid }}\">Heures</span>\n        </div>\n        <span class=\"pb-cd-sep-{{ bid }}\">|</span>\n        <div class=\"pb-cd-block-{{ bid }}\">\n          <span class=\"pb-cd-num-{{ bid }}\" id=\"cd-m-{{ bid }}\">--</span>\n          <span class=\"pb-cd-lbl-{{ bid }}\">Minutes</span>\n        </div>\n        <span class=\"pb-cd-sep-{{ bid }}\">|</span>\n        <div class=\"pb-cd-block-{{ bid }}\">\n          <span class=\"pb-cd-num-{{ bid }}\" id=\"cd-s-{{ bid }}\">--</span>\n          <span class=\"pb-cd-lbl-{{ bid }}\">Secondes</span>\n        </div>\n      </div>\n    </div>\n\n    <button class=\"pb-close-{{ bid }}\" id=\"pb-close-{{ bid }}\" aria-label=\"Fermer\">×</button>\n  </div>\n</div>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600;700&display=swap');\n  #promo-banner-{{ bid }} { font-family:'Raleway',sans-serif; box-sizing:border-box; }\n  .pb-inner-{{ bid }} { position:relative; border-radius:12px; overflow:hidden; max-width:var(--page-width,1200px); margin:0 auto; }\n  .pb-bg-{{ bid }} {\n    position:absolute; inset:-20px;\n    background-color:#d8c9b0;\n    {% if pb_bg_image != blank %}background-image:url('{{ pb_bg_image }}');{% endif %}\n    background-size:cover; background-position:center;\n    filter:blur({{ pb_blur }}px); transform:scale(1.12);\n  }\n  .pb-overlay-{{ bid }} { position:absolute; inset:0; }\n  .pb-content-{{ bid }} { position:relative; z-index:1; padding:20px 52px 20px 28px; display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap; }\n  .pb-text-{{ bid }} { display:flex; flex-direction:column; gap:4px; }\n  .pb-text-top-{{ bid }} { display:flex; flex-direction:row; align-items:center; gap:8px; }\n  .pb-label-{{ bid }} { color:#000; font-size:11px; letter-spacing:.2em; text-transform:uppercase; font-weight:400; }\n  .pb-sep-{{ bid }} { color:rgba(26,26,26,.35); font-size:12px; font-weight:300; }\n  .pb-sub-{{ bid }} { color:#1a1a1a; font-size:11px; letter-spacing:.06em; font-weight:300; }\n  .pb-main-{{ bid }} { color:#1a1a1a; font-size:18px; letter-spacing:.08em; font-weight:600; text-transform:uppercase; line-height:1.2; }\n  .pb-cd-{{ bid }} { display:flex; align-items:center; gap:6px; }\n  .pb-cd-block-{{ bid }} { display:flex; flex-direction:column; align-items:center; background:rgba(255,255,255,.75); border-radius:8px; padding:10px 0; width:72px; }\n  .pb-cd-num-{{ bid }} { font-size:28px; font-weight:700; color:#1a1a1a; line-height:1; font-variant-numeric:tabular-nums lining-nums; letter-spacing:.05em; }\n  .pb-cd-lbl-{{ bid }} { font-size:10px; color:rgba(26,26,26,.5); letter-spacing:.1em; text-transform:uppercase; margin-top:4px; }\n  .pb-cd-sep-{{ bid }} { color:rgba(26,26,26,.25); font-size:20px; font-weight:300; }\n  .pb-close-{{ bid }} { position:absolute; top:12px; right:14px; z-index:2; background:none; border:none; color:rgba(26,26,26,.3); font-size:22px; cursor:pointer; font-weight:300; padding:4px 8px; transition:color .2s; }\n  .pb-close-{{ bid }}:hover { color:#1a1a1a; }\n  @keyframes pb-cd-flip-{{ bid }} {\n    from { opacity:0; transform:translateY(6px); }\n    to   { opacity:1; transform:translateY(0); }\n  }\n  .pb-cd-num-{{ bid }}.pb-cd-anim-{{ bid }} {\n    animation: pb-cd-flip-{{ bid }} 0.2s ease-out;\n  }\n  @media(max-width:640px){\n    .pb-content-{{ bid }} { flex-direction:column; align-items:flex-start; gap:16px; padding:20px 44px 20px 20px; }\n    .pb-main-{{ bid }} { font-size:15px; }\n    .pb-cd-block-{{ bid }} { min-width:52px; padding:8px 12px; }\n    .pb-cd-num-{{ bid }} { font-size:22px; }\n  }\n</style>\n\n<script>\n(function(){\n  var bid='{{ bid }}',storageKey='promo-closed-'+bid;\n  var banner=document.getElementById('promo-banner-'+bid);\n  var btn=document.getElementById('pb-close-'+bid);\n  if(sessionStorage.getItem(storageKey)==='1'){if(banner)banner.style.display='none';return;}\n  if(btn)btn.addEventListener('click',function(){if(banner)banner.style.display='none';sessionStorage.setItem(storageKey,'1');});\n  var target=new Date('{{ pb_end_date }}');\n  function pad(n){return String(n).padStart(2,'0');}\n  function set(id,val){\n    var el=document.getElementById(id+'-'+bid);\n    if(!el)return;\n    var newVal=pad(val);\n    if(el.textContent===newVal)return;\n    el.textContent=newVal;\n    el.classList.remove('pb-cd-anim-'+bid);\n    void el.offsetWidth;\n    el.classList.add('pb-cd-anim-'+bid);\n  }\n  function tick(){\n    var d=target-new Date();\n    if(d<=0){set('cd-d',0);set('cd-h',0);set('cd-m',0);set('cd-s',0);clearInterval(t);return;}\n    set('cd-d',Math.floor(d/86400000));\n    set('cd-h',Math.floor((d%86400000)/3600000));\n    set('cd-m',Math.floor((d%3600000)/60000));\n    set('cd-s',Math.floor((d%60000)/1000));\n  }\n  tick();var t=setInterval(tick,1000);\n})();\n</script>"
              },
