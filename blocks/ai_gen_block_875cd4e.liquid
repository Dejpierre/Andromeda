{% doc %}
  @prompt
    Je veux une section avec les images alignés sur la même ligne et sur mobile en caroussel scrollable, c'est comme des cartes prodiuts mais je dois pouvoir mettre l'image lien et texte que je veux
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-custom-cards-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-custom-cards-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .ai-custom-cards-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-custom-card-{{ ai_gen_id }} {
    flex: 0 0 auto;
    scroll-snap-align: start;
    width: calc((100% - ({{ block.settings.cards_per_row | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row }});
    min-width: 200px;
  }

  .ai-custom-card-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .ai-custom-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.placeholder_bg_color }};
  }

  .ai-custom-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-custom-card-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-custom-card-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-custom-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px 0 0;
  }

  .ai-custom-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.3;
  }

  .ai-custom-card-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-card-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_card_width }}%;
      min-width: {{ block.settings.mobile_card_width }}%;
    }

    .ai-custom-cards-wrapper-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_card_gap }}px;
      padding: 0 {{ block.settings.mobile_padding }}px;
      margin: 0 -{{ block.settings.mobile_padding }}px;
    }
  }
{% endstyle %}

<custom-cards-{{ ai_gen_id }} class="ai-custom-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-custom-cards-container-{{ ai_gen_id }}">
    <div class="ai-custom-cards-wrapper-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_text_key = 'card_' | append: i | append: '_text'
          assign card_link_key = 'card_' | append: i | append: '_link'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_image = block.settings[card_image_key]
          assign card_title = block.settings[card_title_key]
          assign card_text = block.settings[card_text_key]
          assign card_link = block.settings[card_link_key]
        %}

        {% if card_enabled %}
          <div class="ai-custom-card-{{ ai_gen_id }}">
            {% if card_link != blank %}
              <a href="{{ card_link }}" class="ai-custom-card-link-{{ ai_gen_id }}">
            {% else %}
              <div class="ai-custom-card-link-{{ ai_gen_id }}">
            {% endif %}
              <div class="ai-custom-card-image-wrapper-{{ ai_gen_id }}">
                {% if card_image %}
                  <img
                    src="{{ card_image | image_url: width: 800 }}"
                    alt="{{ card_image.alt | escape }}"
                    loading="lazy"
                    width="{{ card_image.width }}"
                    height="{{ card_image.height }}"
                    class="ai-custom-card-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-custom-card-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              {% if card_title != blank or card_text != blank %}
                <div class="ai-custom-card-content-{{ ai_gen_id }}">
                  {% if card_title != blank %}
                    <h3 class="ai-custom-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
                  {% endif %}
                  {% if card_text != blank %}
                    <p class="ai-custom-card-text-{{ ai_gen_id }}">{{ card_text }}</p>
                  {% endif %}
                </div>
              {% endif %}
            {% if card_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</custom-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-custom-cards-wrapper-{{ ai_gen_id }}');
        this.setupMobileScroll();
      }

      setupMobileScroll() {
        if (!this.wrapper) return;

        let isDown = false;
        let startX;
        let scrollLeft;

        this.wrapper.addEventListener('mousedown', (e) => {
          if (window.innerWidth > 749) return;
          isDown = true;
          startX = e.pageX - this.wrapper.offsetLeft;
          scrollLeft = this.wrapper.scrollLeft;
        });

        this.wrapper.addEventListener('mouseleave', () => {
          isDown = false;
        });

        this.wrapper.addEventListener('mouseup', () => {
          isDown = false;
        });

        this.wrapper.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.wrapper.offsetLeft;
          const walk = (x - startX) * 2;
          this.wrapper.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('custom-cards-{{ ai_gen_id }}', CustomCards{{ ai_gen_id }});
  })();
</script>

