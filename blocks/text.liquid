
{%- if block.settings.slidein_enabled and block.settings.slidein_content != blank -%}
  <div
    class="text-slidein__trigger"
    role="button"
    tabindex="0"
    data-slidein-id="slidein-{{ block.id }}"
    aria-expanded="false"
    aria-haspopup="dialog"
  >
    {% render 'text', block: block %}
  </div>

  <div class="text-slidein" id="slidein-{{ block.id }}" role="dialog" aria-modal="true" hidden>
    <button class="text-slidein__overlay" type="button" aria-label="Fermer" tabindex="-1"></button>
    <div class="text-slidein__panel">
      <button class="text-slidein__close" type="button" aria-label="Fermer">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      {%- if block.settings.slidein_title != blank -%}
        <p class="text-slidein__title">{{ block.settings.slidein_title }}</p>
      {%- endif -%}
      <div class="text-slidein__body rte">{{ block.settings.slidein_content }}</div>
      {%- if block.settings.slidein_cta_label != blank and block.settings.slidein_cta_url != blank -%}
        <div class="text-slidein__cta-wrap">
          <a class="text-slidein__cta" href="{{ block.settings.slidein_cta_url }}">
            {{- block.settings.slidein_cta_label -}}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- else -%}
  {% render 'text', block: block %}
{%- endif -%}

{% stylesheet %}
.text-slidein__trigger {
  display: block;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: currentColor;
}
.text-slidein__trigger:hover { opacity: 0.7; }

.text-slidein {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  justify-content: flex-end;
}
.text-slidein[hidden] { display: none; }

.text-slidein__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
  border: none;
  cursor: pointer;
  animation: slidein-fade-in 0.25s ease;
}

.text-slidein__panel {
  position: relative;
  background: #fff;
  width: min(420px, 92vw);
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: -4px 0 24px rgba(0,0,0,0.12);
  animation: slidein-slide-in 0.3s cubic-bezier(0.32,0,0.67,0);
}

.text-slidein__close {
  position: absolute;
  top: calc(var(--header-height, 0px) + 16px);
  right: 16px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  color: var(--color-foreground);
  opacity: 0.6;
  z-index: 1;
}
.text-slidein__close:hover { opacity: 1; }

.text-slidein__title {
  font-size: 1.3rem;
  font-weight: 600;
  margin: 0 0 16px;
  color: var(--color-foreground);
  padding: calc(var(--header-height, 0px) + 48px) 32px 0;
  flex-shrink: 0;
}

.text-slidein__body {
  font-size: 0.95rem;
  line-height: 1.65;
  flex: 1;
  overflow-y: auto;
  padding: calc(var(--header-height, 0px) + 48px) 32px 24px;
}

.text-slidein__title + .text-slidein__body {
  padding-top: 0;
}

.text-slidein__cta-wrap {
  flex-shrink: 0;
  padding: 16px 32px 32px;
  border-top: 1px solid rgba(0,0,0,0.08);
}

.text-slidein__cta {
  display: block;
  text-align: center;
  padding: 12px 24px;
  background: #1C1A18;
  color: #fff;
  text-decoration: none;
  border-radius: 6px;
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  transition: opacity 0.2s ease;
}
.text-slidein__cta:hover { opacity: 0.8; }

@keyframes slidein-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes slidein-slide-in {
  from { transform: translateX(100%); }
  to   { transform: translateX(0); }
}

@media (max-width: 749px) {
  .text-slidein { align-items: flex-end; justify-content: stretch; }
  .text-slidein__panel {
    width: 100%;
    height: 50vh;
    border-radius: 16px 16px 0 0;
    animation: slidein-slide-up 0.3s cubic-bezier(0.32,0,0.67,0);
  }
  .text-slidein__body {
    padding: 24px 24px 16px;
  }
  .text-slidein__title {
    padding: 32px 24px 0;
  }
  .text-slidein__cta-wrap {
    padding: 12px 24px 24px;
  }
  @keyframes slidein-slide-up {
    from { transform: translateY(100%); }
    to   { transform: translateY(0); }
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  document.addEventListener('click', function (e) {
    // Ouvrir
    var trigger = e.target.closest('[data-slidein-id]');
    if (trigger) {
      var id = trigger.dataset.slideinId;
      var panel = document.getElementById(id);
      if (!panel) return;
      panel.hidden = false;
      trigger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      panel.querySelector('.text-slidein__panel')?.focus?.();
      return;
    }

    // Fermer via overlay ou bouton close
    var closer = e.target.closest('.text-slidein__close, .text-slidein__overlay');
    if (closer) {
      var slidein = closer.closest('.text-slidein');
      if (!slidein) return;
      closeSlidein(slidein);
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      var open = document.querySelector('.text-slidein:not([hidden])');
      if (open) closeSlidein(open);
      return;
    }
    if (e.key === 'Enter' || e.key === ' ') {
      var trigger = e.target.closest('[data-slidein-id]');
      if (!trigger) return;
      e.preventDefault();
      var id = trigger.dataset.slideinId;
      var panel = document.getElementById(id);
      if (!panel) return;
      panel.hidden = false;
      trigger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
  });

  function closeSlidein(el) {
    el.hidden = true;
    document.body.style.overflow = '';
    var id = el.id;
    var trigger = document.querySelector('[data-slidein-id="' + id + '"]');
    if (trigger) trigger.setAttribute('aria-expanded', 'false');
  }
})();
{% endjavascript %}

