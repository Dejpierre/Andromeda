{% doc %}
  @prompt
    Pour reprendre tes specs :
    
    Image de fond, largeur alignée aux autres sections
    Hauteur adaptée au contenu
    Titre + texte + CTA centré en superposition
    Bouton CTA plein (solid)
    Overlay derrière le contenu (z-index correct dès le départ), l'image de fond doit être en cover, la couleur du titre doit être en blanc, il me faut de la marge en bas de la section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    overflow: hidden;
    border-radius: 32px;
    min-height: {{ block.settings.min_height }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-banner__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-hero-banner__content-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-hero-banner__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
  }

  .ai-hero-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    max-width: {{ block.settings.text_max_width }}px;
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-hero-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-hero-banner__content-wrapper-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-hero-banner__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-hero-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | default: block.settings.title | default: 'Andromeda Paris' | escape }}"
        title="{{ block.settings.background_image.alt | default: block.settings.title | default: 'Andromeda Paris' | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-banner__background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-banner__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-banner__content-wrapper-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-hero-banner__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-hero-banner__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-hero-banner__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

