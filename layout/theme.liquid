<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {% if request.page_type == 'password' %}
      <meta name="robots" content="noindex, nofollow">
    {% endif %}
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Afacad:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
    

  <!-- JSON-LD Structured Data — Andromeda -->
  {%- if request.page_type == 'product' -%}
  {%- assign jm = product.metafields.judgeme -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 300 | json }},
    "image": [
      {%- for image in product.images -%}
        {{ image | image_url: width: 800 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    "brand": {
      "@type": "Brand",
      "name": "Andromeda Paris"
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "lowPrice": {{ product.price_min | divided_by: 100.0 }},
      "highPrice": {{ product.price_max | divided_by: 100.0 }},
      "offerCount": {{ product.variants.size }},
      "availability": {%- if product.available -%}"https://schema.org/InStock"{%- else -%}"https://schema.org/OutOfStock"{%- endif -%},
      "url": {{ shop.url | append: product.url | json }}
    },
    "url": {{ shop.url | append: product.url | json }}
    {%- if jm.rating and jm.rating_count -%}
    ,"aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ jm.rating }}",
      "reviewCount": "{{ jm.rating_count }}",
      "bestRating": "5",
      "worstRating": "1"
    }
    {%- endif -%}
  }
  </script>
  {%- endif -%}

  {%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quelle est la différence entre soie 22 mommes et 19 mommes ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Les mommes désignent le poids du tissu. À 22 mommes, notre soie est plus dense, plus opaque et plus durable qu'une soie 19 mommes. Elle bloque 100% de la lumière et conserve sa douceur lavage après lavage — là où un tissu moins épais se dégrade plus vite."
        }
      },
      {
        "@type": "Question",
        "name": "Qu'est-ce que le grade 6A de la soie ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le grade 6A est la classification la plus haute de la soie de mûrier. Moins de 5% de la production mondiale l'atteint. Les filaments sont extra-longs, sans nœuds ni irrégularités — ce qui donne une surface parfaitement lisse, douce et homogène au contact de votre peau."
        }
      },
      {
        "@type": "Question",
        "name": "Comment laver mon masque Andromeda ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Lavage à la main à l'eau froide avec un savon doux, ou en machine sur cycle délicat (30°C max, filet de lavage recommandé). Séchage à plat, loin de toute source de chaleur. La soie est naturellement antibactérienne — un lavage tous les 7 à 10 jours est suffisant."
        }
      },
      {
        "@type": "Question",
        "name": "C'est quoi le QR code inclus dans ma commande ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Chaque masque Andromeda est livré avec un QR code donnant accès à notre espace rituel exclusif — une sélection de sons d'ambiance conçus pour accompagner l'endormissement : pluie, forêt, océan, sons binauraux. Une expérience sensorielle unique, réservée à nos clients."
        }
      },
      {
        "@type": "Question",
        "name": "Le masque est-il adapté aux dormeurs sur le côté ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui. L'élastique réglable est conçu pour ne pas exercer de pression sur la tête ni marquer la peau. Le masque reste en place toute la nuit quelle que soit votre position de sommeil."
        }
      },
      {
        "@type": "Question",
        "name": "Sous combien de temps suis-je livré(e) ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Livraison en France sous 2 à 4 jours ouvrés. Livraison internationale sous 5 à 10 jours. Chaque commande est expédiée dans un emballage soigné, prête à offrir."
        }
      }
    ]
  }
  </script>
  {%- endif -%}

  {%- if request.page_type == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://www.andromedaparis.com/#organization",
        "name": "Andromeda Paris",
        "url": "https://www.andromedaparis.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://www.andromedaparis.com/cdn/shop/files/logo-andromeda.png",
          "width": 300,
          "height": 80
        },
        "description": "Masques de sommeil en pure soie de mûrier Grade 6A, 22 mommes. Accessoires de sommeil haut de gamme fabriqués pour une nuit de sommeil optimale.",
        "foundingDate": "2024",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "FR"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "email": "contact@andromedaparis.com",
          "availableLanguage": "French"
        },
        "sameAs": [
          "https://www.instagram.com/andromeda_paris/",
          "https://www.facebook.com/profile.php?id=61573303544976",
          "https://fr.pinterest.com/andromedaparisfr/",
          "https://www.tiktok.com/@andromeda_paris"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://www.andromedaparis.com/#website",
        "url": "https://www.andromedaparis.com",
        "name": "Andromeda Paris",
        "description": "Masques de sommeil en pure soie de mûrier Grade 6A — Andromeda Paris",
        "publisher": {
          "@id": "https://www.andromedaparis.com/#organization"
        },
        "inLanguage": "fr-FR",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://www.andromedaparis.com/search?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  }
  </script>
  {%- endif -%}

</head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
