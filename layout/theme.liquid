<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {% if request.page_type == 'password' %}
      <meta name="robots" content="noindex, nofollow">
    {% endif %}
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Afacad:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
    

  <!-- JSON-LD Structured Data — Andromeda -->

  {%- if request.page_type == 'product' or request.page_type == 'article' or request.page_type == 'collection' or request.page_type == 'blog' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": {{ shop.url | json }}
      }
      {%- if request.page_type == 'product' -%}
      {%- if product.collections.first -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.collections.first.title | json }},
        "item": {{ shop.url | append: product.collections.first.url | json }}
      }
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": {{ shop.url | append: product.url | json }}
      }
      {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }},
        "item": {{ shop.url | append: product.url | json }}
      }
      {%- endif -%}
      {%- elsif request.page_type == 'article' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ shop.url | append: blog.url | json }}
      }
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ article.title | json }},
        "item": {{ shop.url | append: article.url | json }}
      }
      {%- elsif request.page_type == 'collection' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ shop.url | append: collection.url | json }}
      }
      {%- elsif request.page_type == 'blog' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ shop.url | append: blog.url | json }}
      }
      {%- endif -%}
    ]
  }
  </script>
  {%- endif -%}

  {%- if request.page_type == 'product' -%}
  {%- assign jm = product.metafields.judgeme -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 300 | json }},
    "image": [
      {%- for image in product.images -%}
        {{ image | image_url: width: 800 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    "brand": {
      "@type": "Brand",
      "name": "Andromeda Paris"
    },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "lowPrice": {{ product.price_min | divided_by: 100.0 }},
      "highPrice": {{ product.price_max | divided_by: 100.0 }},
      "offerCount": {{ product.variants.size }},
      "priceValidUntil": "{{ 'now' | date: '%Y' }}-12-31",
      "availability": {%- if product.available -%}"https://schema.org/InStock"{%- else -%}"https://schema.org/OutOfStock"{%- endif -%},
      "url": {{ shop.url | append: product.url | json }}
    },
    "url": {{ shop.url | append: product.url | json }}
    {%- if jm.rating and jm.rating_count -%}
    ,"aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ jm.rating }}",
      "reviewCount": "{{ jm.rating_count }}",
      "bestRating": "5",
      "worstRating": "1"
    }
    {%- endif -%}
    ,"shippingDetails": [
      {
        "@type": "OfferShippingDetails",
        "shippingRate": { "@type": "MonetaryAmount", "value": "3.60", "currency": "EUR" },
        "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "FR" },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 1, "unitCode": "DAY" },
          "transitTime": { "@type": "QuantitativeValue", "minValue": 2, "maxValue": 4, "unitCode": "DAY" }
        }
      },
      {
        "@type": "OfferShippingDetails",
        "shippingRate": { "@type": "MonetaryAmount", "value": "9.90", "currency": "EUR" },
        "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "BE" },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 1, "unitCode": "DAY" },
          "transitTime": { "@type": "QuantitativeValue", "minValue": 5, "maxValue": 10, "unitCode": "DAY" }
        }
      }
    ]
    ,"hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "FR",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 30,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  }
  </script>
  {%- endif -%}

  {%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Quelle est la différence entre soie 22 mommes et 19 mommes ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Les mommes mesurent la densité du tissu de soie. À 22 mommes, la soie Andromeda est 15 à 20 % plus dense qu'une soie 19 mommes standard. Elle bloque 100 % de la lumière, résiste mieux aux lavages répétés et conserve sa douceur au fil du temps. Une soie 19 mommes, plus fine, perd ses propriétés plus rapidement."
        }
      },
      {
        "@type": "Question",
        "name": "Qu'est-ce que le grade 6A de la soie ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le grade 6A est la plus haute classification mondiale de la soie de mûrier. Moins de 5 % de la production mondiale atteint ce niveau. Les filaments sont extra-longs, uniformes, sans nœuds ni irrégularités. Le résultat : une surface parfaitement lisse et homogène, idéale pour le contact prolongé avec la peau et les cheveux pendant le sommeil."
        }
      },
      {
        "@type": "Question",
        "name": "La soie est-elle bonne pour la peau et les cheveux ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui. La soie de mûrier génère très peu de friction comparée au coton ou au synthétique — elle réduit les marques de pression sur la peau et les cassures capillaires. Elle est naturellement thermorégulatrice (fraîche en été, douce en hiver), hypoallergénique, et ne crée pas d'électricité statique. Ces propriétés en font le matériau de référence pour les accessoires de sommeil haut de gamme."
        }
      },
      {
        "@type": "Question",
        "name": "Le masque bloque-t-il vraiment 100 % de la lumière ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui. Grâce à la densité de la soie 22 mommes et à la coupe anatomique du masque, l'obscurité est totale quelle que soit la source lumineuse. La forme enveloppante laisse une légère cavité pour les yeux, ce qui évite toute pression sur les paupières tout en garantissant une opacité complète."
        }
      },
      {
        "@type": "Question",
        "name": "Le masque est-il certifié ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui. Le masque Andromeda est certifié OEKO-TEX® STANDARD 100, ce qui garantit l'absence de substances nocives dans le tissu — colorants, métaux lourds, pesticides. C'est la certification textile la plus reconnue au monde pour la sécurité des produits en contact avec la peau."
        }
      },
      {
        "@type": "Question",
        "name": "Comment laver mon masque Andromeda ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Lavage à la main à l'eau froide avec un savon doux (type savon de Marseille ou shampoing délicat), ou en machine sur cycle délicat à 30 °C maximum dans un filet de lavage. Séchage à plat, à l'air libre, loin de toute source de chaleur directe. Ne pas essorer. La soie étant naturellement antibactérienne, un lavage tous les 7 à 10 jours est suffisant pour un usage quotidien."
        }
      },
      {
        "@type": "Question",
        "name": "Le masque est-il adapté aux dormeurs sur le côté ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui. L'élastique réglable en soie est conçu pour s'adapter à toutes les morphologies sans exercer de pression sur la tête ni laisser de marques sur la peau au réveil. Le masque reste en place toute la nuit quelle que soit la position de sommeil — sur le dos, sur le côté ou en position mixte."
        }
      },
      {
        "@type": "Question",
        "name": "C'est quoi le QR code inclus dans ma commande ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Chaque masque Andromeda est livré avec un QR code donnant accès à l'espace rituel exclusif — une sélection de sons d'ambiance conçus pour accompagner l'endormissement : pluie, forêt, océan, sons binauraux. Cet accès est permanent et réservé aux clients Andromeda."
        }
      },
      {
        "@type": "Question",
        "name": "Sous combien de temps suis-je livré(e) ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Livraison en France métropolitaine sous 2 à 4 jours ouvrés. Livraison internationale (Europe, monde) sous 5 à 10 jours ouvrés. Chaque commande est expédiée dans un emballage soigné, prête à offrir. La livraison est offerte dès 65 € d'achat."
        }
      },
      {
        "@type": "Question",
        "name": "Quelle est la politique de retour ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Vous disposez de 30 jours à compter de la réception pour retourner votre masque si vous n'êtes pas entièrement satisfait(e). Le retour est gratuit. Le remboursement est effectué dans les 5 à 7 jours ouvrés après réception de l'article."
        }
      }
    ]
  }
  </script>
  {%- endif -%}

