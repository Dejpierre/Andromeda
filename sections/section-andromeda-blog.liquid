{% comment %} Blog listing — Andromeda style {% endcomment %}

{% paginate blog.articles by section.settings.articles_per_page %}

<div class="andro-blog" id="andro-blog">

  <!-- Header dark -->
  <header class="andro-blog__header">
    <div class="andro-blog__header-bg" aria-hidden="true">
      <div class="andro-blog__stars andro-blog__stars--1"></div>
      <div class="andro-blog__stars andro-blog__stars--2"></div>
    </div>
    <div class="andro-blog__header-inner">
      <p class="andro-blog__eyebrow">{{ section.settings.eyebrow | default: 'Journal' }}</p>
      <h1 class="andro-blog__title">{{ section.settings.heading | default: blog.title }}</h1>
      {% if section.settings.subtitle != blank %}
        <p class="andro-blog__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
  </header>

  <!-- Articles grid (fond clair) -->
  <div class="andro-blog__grid">
    {% for article in blog.articles %}
      <article class="andro-blog__card{% if forloop.first %} andro-blog__card--hero{% endif %}">

        {% if article.image %}
          <a href="{{ article.url }}" class="andro-blog__card-img-wrap" tabindex="-1" aria-hidden="true">
            <img
              src="{{ article.image | image_url: width: 1200 }}"
              alt="{{ article.image.alt | default: article.title | escape }}"
              class="andro-blog__card-img"
              loading="{% if forloop.index <= 2 %}eager{% else %}lazy{% endif %}"
              width="{{ article.image.width }}"
              height="{{ article.image.height }}"
            >
            <div class="andro-blog__card-overlay"></div>
          </a>
        {% endif %}

        <div class="andro-blog__card-body">
          <div class="andro-blog__card-meta">
            <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
              {{ article.published_at | date: '%d %B %Y' }}
            </time>
            {% if article.tags.size > 0 %}
              <span class="andro-blog__card-tag">{{ article.tags | first }}</span>
            {% endif %}
          </div>

          <h2 class="andro-blog__card-title">
            <a href="{{ article.url }}">{{ article.title }}</a>
          </h2>

          {% if article.excerpt != blank %}
            <p class="andro-blog__card-excerpt">{{ article.excerpt | strip_html | truncate: 140 }}</p>
          {% endif %}

          <a href="{{ article.url }}" class="andro-blog__card-link" aria-label="Lire {{ article.title }}">
            Lire la suite
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

      </article>
    {% else %}
      <p class="andro-blog__empty">Aucun article pour le moment.</p>
    {% endfor %}
  </div>

  <!-- Pagination -->
  {% if paginate.pages > 1 %}
    <nav class="andro-blog__pagination" aria-label="Pagination">
      {% if paginate.previous %}
        <a href="{{ paginate.previous.url }}" class="andro-blog__page-btn">← Précédent</a>
      {% endif %}
      <span class="andro-blog__page-info">{{ paginate.current_page }} / {{ paginate.pages }}</span>
      {% if paginate.next %}
        <a href="{{ paginate.next.url }}" class="andro-blog__page-btn">Suivant →</a>
      {% endif %}
    </nav>
  {% endif %}

</div>

{% endpaginate %}

<style>
  @font-face {
    font-family: 'Stellar';
    src: url('https://cdn.shopify.com/s/files/1/1000/9375/5727/files/MirageStellar.ttf?v=1772405200') format('opentype');
    font-weight: normal; font-style: normal; font-display: swap;
  }

  /* ── Base ─────────────────────────────────────────────── */
  .andro-blog { background: #FAF7F2; color: #3A3733; }

  /* ── Stars (scoped au header) ─────────────────────────── */
  .andro-blog__header-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .andro-blog__stars { position: absolute; inset: 0; }
  .andro-blog__stars--1 {
    background-image:
      radial-gradient(1.2px 1.2px at 8% 15%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(1px 1px at 22% 72%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 38% 28%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 52% 85%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.3px 1.3px at 67% 10%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(0.9px 0.9px at 78% 55%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.4px 1.4px at 91% 38%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 14% 90%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 45% 50%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(1.1px 1.1px at 85% 80%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1.4px 1.4px at 55% 5%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 95% 20%, rgba(255,255,255,0.6) 0%, transparent 100%);
    animation: andro-drift-1 35s ease-in-out infinite;
  }
  .andro-blog__stars--2 {
    background-image:
      radial-gradient(1px 1px at 12% 25%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.3px 1.3px at 35% 60%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(0.9px 0.9px at 58% 18%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 74% 42%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(0.8px 0.8px at 48% 75%, rgba(255,255,255,0.4) 0%, transparent 100%);
    animation: andro-drift-2 50s ease-in-out infinite; opacity: 0.7;
  }
  @keyframes andro-drift-1 {
    0%, 100% { transform: translate(0,0); } 33% { transform: translate(-10px,-7px); } 66% { transform: translate(7px,-12px); }
  }
  @keyframes andro-drift-2 {
    0%, 100% { transform: translate(0,0); } 40% { transform: translate(9px,-5px); } 70% { transform: translate(-7px,9px); }
  }

  /* ── Header dark ──────────────────────────────────────── */
  .andro-blog__header {
    position: relative;
    background: #191A2E;
    overflow: hidden;
    text-align: center;
    padding-bottom: 72px;
  }
  .andro-blog__header > *:not(.andro-blog__header-bg) { position: relative; z-index: 1; }
  .andro-blog__header-inner { max-width: 700px; margin: 0 auto; padding: 90px 24px 0; }

  .andro-blog__eyebrow {
    font-size: 10px; font-weight: 400; letter-spacing: 0.4em; text-transform: uppercase;
    color: #C8B89A; margin-bottom: 16px;
  }
  #andro-blog .andro-blog__title,
  .andro-blog__title {
    font-family: 'Stellar', serif !important;
    font-size: clamp(36px, 6vw, 60px) !important;
    font-weight: normal !important; color: #FFFFFF !important;
    word-spacing: -0.22em !important; letter-spacing: 0 !important;
    line-height: 1.1 !important; margin-bottom: 16px;
  }
  .andro-blog__subtitle {
    font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.5);
    letter-spacing: 0.04em; line-height: 1.7; max-width: 420px; margin: 0 auto;
  }

  /* ── Grid (fond clair) ────────────────────────────────── */
  .andro-blog__grid {
    max-width: 960px; margin: 0 auto;
    padding: 48px 24px 80px;
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
  }
  .andro-blog__card--hero { grid-column: 1 / -1; }

  /* ── Card ─────────────────────────────────────────────── */
  .andro-blog__card {
    border-radius: 12px; overflow: hidden;
    background: #FFFFFF;
    border: 1px solid rgba(184,151,90,0.15);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.25s cubic-bezier(.34,1.56,.64,1), box-shadow 0.25s ease;
  }
  .andro-blog__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
  }
  .andro-blog__card-img-wrap {
    display: block; position: relative; overflow: hidden; aspect-ratio: 16/9;
  }
  .andro-blog__card--hero .andro-blog__card-img-wrap { aspect-ratio: 2.8/1; }
  .andro-blog__card-img {
    width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.55s ease;
  }
  .andro-blog__card:hover .andro-blog__card-img { transform: scale(1.04); }
  .andro-blog__card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(28,26,24,0.45) 0%, transparent 55%);
  }

  /* ── Card body ────────────────────────────────────────── */
  .andro-blog__card-body { padding: 20px 24px 26px; }
  .andro-blog__card--hero .andro-blog__card-body { padding: 24px 32px 32px; }

  .andro-blog__card-meta {
    display: flex; align-items: center; gap: 12px;
    font-size: 10px; font-weight: 300; letter-spacing: 0.15em; text-transform: uppercase;
    color: #AAA49E; margin-bottom: 12px;
  }
  .andro-blog__card-tag {
    color: #B8975A; border: 1px solid rgba(184,151,90,0.35);
    border-radius: 20px; padding: 2px 10px; font-size: 9px;
  }
  .andro-blog__card-title {
    font-size: 18px; font-weight: 500; color: #1C1A18; line-height: 1.35; margin-bottom: 10px;
  }
  .andro-blog__card--hero .andro-blog__card-title { font-size: 26px; }
  .andro-blog__card-title a { color: inherit; text-decoration: none; transition: color 0.2s; }
  .andro-blog__card-title a:hover { color: #B8975A; }
  .andro-blog__card-excerpt {
    font-size: 13px; font-weight: 300; color: #8A837A; line-height: 1.65; margin-bottom: 18px;
  }
  .andro-blog__card-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 10px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase;
    color: #B8975A; text-decoration: none; transition: gap 0.2s ease;
  }
  .andro-blog__card-link:hover { gap: 10px; }

  /* ── Empty / Pagination ──────────────────────────────── */
  .andro-blog__empty {
    grid-column: 1/-1; text-align: center; color: #AAA49E; padding: 60px 0; font-weight: 300;
  }
  .andro-blog__pagination {
    display: flex; align-items: center; justify-content: center; gap: 24px; padding-bottom: 80px;
  }
  .andro-blog__page-btn {
    font-size: 11px; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase;
    color: #B8975A; text-decoration: none; border: 1px solid rgba(184,151,90,0.35);
    padding: 10px 20px; border-radius: 40px; transition: background 0.2s;
  }
  .andro-blog__page-btn:hover { background: rgba(184,151,90,0.08); }
  .andro-blog__page-info { font-size: 11px; letter-spacing: 0.15em; color: #AAA49E; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .andro-blog__grid { grid-template-columns: 1fr; }
    .andro-blog__card--hero { grid-column: 1; }
    .andro-blog__card--hero .andro-blog__card-img-wrap { aspect-ratio: 16/9; }
    .andro-blog__header-inner { padding-top: 64px; }
  }
</style>

{% schema %}
{
  "name": "Blog Andromeda",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texte au-dessus du titre",
      "default": "Journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre (laisse vide = nom du blog)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles par page",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 9
    }
  ],
  "presets": [
    {
      "name": "Blog Andromeda"
    }
  ]
}
{% endschema %}
