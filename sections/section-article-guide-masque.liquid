  }
  @keyframes ag-drift-1 {
    0%, 100% { transform: translate(0,0); }
    33%       { transform: translate(-10px,-7px); }
    66%       { transform: translate(7px,-12px); }
  }
  @keyframes ag-drift-2 {
    0%, 100% { transform: translate(0,0); }
    40%       { transform: translate(9px,-5px); }
    70%       { transform: translate(-7px,9px); }
  }

  /* ── Back ────────────────────────────────────────────── */
  .ag__back-wrap { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; padding: 40px 24px 0; }
  .ag__back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(255,255,255,0.38); text-decoration: none; transition: color 0.2s;
  }
