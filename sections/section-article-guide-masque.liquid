    margin: 28px 0 36px; border: 1px solid rgba(184,151,90,0.25); border-radius: 8px; overflow: hidden;
  }
  .ag__table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .ag__table thead { background: #1C1A18; }
