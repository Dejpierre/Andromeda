{% comment %} Article guide masque — Andromeda dark theme — contenu natif article {% endcomment %}

<div class="ag" id="ag">

  <!-- HERO dark -->
  <header class="ag__hero">
    <div class="ag__hero-bg" aria-hidden="true">
      <div class="ag__stars ag__stars--1"></div>
      <div class="ag__stars ag__stars--2"></div>
    </div>

    <div class="ag__back-wrap">
      <a href="/blogs/actualites" class="ag__back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Journal
      </a>
    </div>

    <div class="ag__hero-inner">
      <p class="ag__eyebrow">Andromeda Paris — Guide</p>
      <h1 class="ag__title">{{ article.title }}</h1>
      {% if article.excerpt != blank %}
        <p class="ag__subtitle">{{ article.excerpt | strip_html }}</p>
      {% endif %}
      <div class="ag__meta">
        <span>{{ article.published_at | date: "%d %B %Y" }}</span>
        {% if article.tags.size > 0 %}
          {% for tag in article.tags limit: 2 %}
            <span>{{ tag }}</span>
          {% endfor %}
        {% endif %}
      </div>

      <div class="ag__author">
        <span class="ag__author-avatar" aria-hidden="true">A</span>
        <div>
          <span class="ag__author-name">L'équipe Andromeda Paris</span>
          <span class="ag__author-bio">Spécialistes du sommeil &amp; de la soie de mûrier</span>
        </div>
      </div>
    </div>
  </header>

  <!-- IMAGE HERO (image mise en avant de l'article) -->
  {% if article.image %}
  <div class="ag__featured-img-wrap">
    <img
      src="{{ article.image | image_url: width: 1400 }}"
      alt="{{ article.image.alt | default: article.title }}"
      class="ag__featured-img"
      loading="eager"
      width="{{ article.image.width }}"
      height="{{ article.image.height }}"
    >
  </div>
  {% endif %}

  <!-- ARTICLE BODY — contenu natif Shopify -->
  <div class="ag__body ag__rte">
    {{ article.content }}
  </div>

  <!-- CTA dark -->
  <div class="ag__cta">
    <div class="ag__cta-bg" aria-hidden="true">
      <div class="ag__stars ag__stars--1"></div>
      <div class="ag__stars ag__stars--2"></div>
    </div>
    <div class="ag__cta-inner">
      <p class="ag__cta-eyebrow">Andromeda Paris</p>
      <h2 class="ag__cta-title">Le standard du sommeil d'exception</h2>
      <p class="ag__cta-text">Soie de mûrier. Grade 6A. 22 mommes. Chaque nuit devrait ressembler à la dernière.</p>
      <div class="ag__cta-specs">
        <div class="ag__cta-spec">
          <span class="ag__cta-val">6A</span>
          <span class="ag__cta-lbl">Grade soie</span>
        </div>
        <div class="ag__cta-spec">
          <span class="ag__cta-val">22mm</span>
          <span class="ag__cta-lbl">Mommes</span>
        </div>
        <div class="ag__cta-spec">
          <span class="ag__cta-val">&lt;5%</span>
          <span class="ag__cta-lbl">Production mondiale</span>
        </div>
      </div>
      <a href="/products/" class="ag__cta-btn">Découvrir le masque</a>
    </div>
  </div>

</div>

<style>
  @font-face {
    font-family: 'Stellar';
    src: url('https://cdn.shopify.com/s/files/1/1000/9375/5727/files/MirageStellar.ttf?v=1772405200') format('opentype');
    font-weight: normal; font-style: normal; font-display: swap;
  }

  /* ── Base ────────────────────────────────────────────── */
  .ag { background: #FAF7F2; color: #3A3733; }

  /* ── Stars ───────────────────────────────────────────── */
  .ag__hero-bg, .ag__cta-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .ag__stars { position: absolute; inset: 0; }
  .ag__stars--1 {
    background-image:
      radial-gradient(1.2px 1.2px at 8% 15%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(1px 1px at 22% 72%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 38% 28%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 52% 85%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.3px 1.3px at 67% 10%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(0.9px 0.9px at 78% 55%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.4px 1.4px at 91% 38%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 14% 90%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 45% 50%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(1.1px 1.1px at 85% 80%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1.3px 1.3px at 30% 42%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(0.9px 0.9px at 72% 68%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 95% 20%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1.4px 1.4px at 55% 5%, rgba(255,255,255,0.65) 0%, transparent 100%);
    animation: ag-drift-1 35s ease-in-out infinite;
  }
  .ag__stars--2 {
    background-image:
      radial-gradient(1px 1px at 12% 25%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.3px 1.3px at 35% 60%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(0.9px 0.9px at 58% 18%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 74% 42%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 75%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(0.8px 0.8px at 48% 75%, rgba(255,255,255,0.4) 0%, transparent 100%);
    animation: ag-drift-2 50s ease-in-out infinite; opacity: 0.7;
  }
  @keyframes ag-drift-1 {
    0%, 100% { transform: translate(0,0); }
    33%       { transform: translate(-10px,-7px); }
    66%       { transform: translate(7px,-12px); }
  }
  @keyframes ag-drift-2 {
    0%, 100% { transform: translate(0,0); }
    40%       { transform: translate(9px,-5px); }
    70%       { transform: translate(-7px,9px); }
  }

  /* ── Back ────────────────────────────────────────────── */
  .ag__back-wrap { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; padding: 40px 24px 0; }
  .ag__back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase;
    color: rgba(255,255,255,0.38); text-decoration: none; transition: color 0.2s;
  }
  .ag__back:hover { color: #C8B89A; }

  /* ── Hero ────────────────────────────────────────────── */
  .ag__hero {
    position: relative;
    background: #191A2E;
    text-align: center;
    padding-bottom: 72px;
    overflow: hidden;
  }
  .ag__hero > *:not(.ag__hero-bg) { position: relative; z-index: 1; }
  .ag__hero-inner { max-width: 760px; margin: 0 auto; padding: 48px 24px 0; }
  .ag__eyebrow {
    font-size: 10px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;
    color: #C8B89A; margin-bottom: 24px;
  }
  #ag .ag__title, .ag__title {
    font-family: 'Stellar', serif !important;
    font-size: clamp(36px, 6vw, 62px) !important;
    font-weight: normal !important;
    color: #FFFFFF !important;
    word-spacing: -0.22em !important;
    letter-spacing: 0 !important;
    line-height: 1.1 !important;
    margin-bottom: 24px;
  }
  .ag__title em { font-style: italic; color: #C8B89A; }
  .ag__subtitle {
    font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.5);
    max-width: 520px; margin: 0 auto 36px; line-height: 1.7; letter-spacing: 0.02em;
  }
  .ag__meta {
    display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 24px;
    font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.3);
    margin-bottom: 28px;
  }
  .ag__meta span { display: flex; align-items: center; gap: 8px; }
  .ag__meta span::before {
    content: ''; display: inline-block; width: 4px; height: 4px;
    border-radius: 50%; background: #C8B89A; opacity: 0.6;
  }
  .ag__author {
    display: inline-flex; align-items: center; gap: 10px;
  }
  .ag__author-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(200,184,154,0.15); border: 1px solid rgba(200,184,154,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 600; color: #C8B89A; flex-shrink: 0;
  }
  .ag__author-name {
    display: block; font-size: 11px; font-weight: 500;
    color: rgba(255,255,255,0.7); letter-spacing: 0.04em;
  }
  .ag__author-bio {
    display: block; font-size: 10px; font-weight: 300;
    color: rgba(255,255,255,0.3); letter-spacing: 0.04em; margin-top: 2px;
  }

  /* ── Image mise en avant ─────────────────────────────── */
  .ag__featured-img-wrap {
    max-width: 900px;
    margin: -40px auto 0;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }
  .ag__featured-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    box-shadow: 0 24px 60px rgba(25,26,46,0.18);
  }

  /* ── Body (fond clair) ───────────────────────────────── */
  .ag__body {
    max-width: 760px; margin: 0 auto; padding: 0 24px;
    background: #FAF7F2;
  }

  /* ── RTE — styles pour le contenu natif Shopify ─────── */
  .ag__rte { padding-top: 56px; padding-bottom: 56px; }

  .ag__rte p {
    font-size: 15px; font-weight: 300; color: #5A5450;
    line-height: 1.85; margin-bottom: 20px;
  }
  .ag__rte h2 {
    font-size: clamp(24px, 3.5vw, 34px); font-weight: 400;
    color: #1C1A18; line-height: 1.2; margin: 52px 0 20px; letter-spacing: -0.01em;
  }
  .ag__rte h3 {
    font-size: 15px; font-weight: 600;
    color: #1C1A18; line-height: 1.5;
    margin: 32px 0 8px;
    padding-left: 16px;
    border-left: 2px solid #B8975A;
    letter-spacing: 0.01em;
  }
  .ag__rte h4 {
    font-size: 14px; font-weight: 600; color: #1C1A18;
    letter-spacing: 0.08em; text-transform: uppercase; margin: 28px 0 10px;
  }
  .ag__rte em { color: #B8975A; font-style: italic; }
  .ag__rte strong { font-weight: 600; color: #1C1A18; }

  .ag__rte img {
    width: 100%; height: auto; display: block;
    border-radius: 12px; margin: 36px 0;
  }

  .ag__rte blockquote {
    border-left: 2px solid #B8975A;
    padding: 16px 0 16px 28px;
    margin: 36px 0;
  }
  .ag__rte blockquote p {
    font-size: 19px !important; font-weight: 300 !important; font-style: italic;
    color: #3A3733 !important; line-height: 1.6 !important; margin: 0 !important;
    font-family: Georgia, serif;
  }

  .ag__rte ul, .ag__rte ol {
    padding-left: 24px; margin-bottom: 20px;
  }
  .ag__rte ul li, .ag__rte ol li {
    font-size: 15px; font-weight: 300; color: #5A5450;
    line-height: 1.8; margin-bottom: 6px;
  }
  .ag__rte ul li::marker { color: #B8975A; }

  .ag__rte hr {
    border: none;
    border-top: 1px solid rgba(184,151,90,0.2);
    margin: 48px 0;
  }

  .ag__rte table {
    width: 100%; border-collapse: collapse; font-size: 13px;
    border: 1px solid rgba(184,151,90,0.25); border-radius: 8px;
    overflow: hidden; margin: 28px 0 36px;
  }
  .ag__rte table thead { background: #1C1A18; }
  .ag__rte table thead th {
    padding: 13px 18px; text-align: left; font-weight: 400;
    letter-spacing: 0.1em; font-size: 10px; text-transform: uppercase;
    color: rgba(250,247,242,0.7);
  }
  .ag__rte table tbody tr { border-bottom: 1px solid rgba(184,151,90,0.15); }
  .ag__rte table tbody tr:last-child { border-bottom: none; }
  .ag__rte table td {
    padding: 13px 18px; color: #5A5450; vertical-align: middle;
  }
  .ag__rte table td:first-child { color: #1C1A18; font-weight: 500; }

  .ag__rte a {
    color: #B8975A; text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── CTA (dark) ──────────────────────────────────────── */
  .ag__cta {
    position: relative; background: #191A2E;
    padding: 80px 24px; text-align: center; overflow: hidden;
  }
  .ag__cta-bg { z-index: 0; }
  .ag__cta > *:not(.ag__cta-bg) { position: relative; z-index: 1; }
  .ag__cta-inner { max-width: 600px; margin: 0 auto; }
  .ag__cta-eyebrow {
    font-size: 10px; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;
    color: #C8B89A; margin-bottom: 16px;
  }
  .ag__cta-title {
    font-size: clamp(28px, 4vw, 44px); font-weight: 400;
    color: #FFFFFF; margin-bottom: 14px; line-height: 1.15;
  }
  .ag__cta-text {
    font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.45);
    max-width: 380px; margin: 0 auto 40px; line-height: 1.7;
  }
  .ag__cta-specs { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; margin-bottom: 40px; }
  .ag__cta-spec { text-align: center; }
  .ag__cta-val {
    font-size: 30px; font-weight: 300; color: #C8B89A;
    display: block; line-height: 1; margin-bottom: 6px; font-family: Georgia, serif;
  }
  .ag__cta-lbl { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.3); }
  .ag__cta-btn {
    display: inline-block; padding: 14px 44px;
    border: 1px solid rgba(200,184,154,0.5); color: #C8B89A;
    font-size: 11px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase;
    text-decoration: none; border-radius: 40px; transition: background 0.25s;
  }
  .ag__cta-btn:hover { background: rgba(200,184,154,0.12); }

  /* ── Classes article (contenu natif avec classes custom) ── */
  .ag__intro { padding: 52px 0 40px; border-bottom: 1px solid rgba(184,151,90,0.18); margin-bottom: 8px; }
  .ag__intro-lead { font-size: 22px; font-weight: 300; font-style: italic; color: #3A3733; line-height: 1.6; margin-bottom: 18px; font-family: Georgia, serif; }
  .ag__intro p { font-size: 15px; font-weight: 300; color: #5A5450; line-height: 1.85; }

  .ag__section { padding: 52px 0 0; }
  .ag__section-label { font-size: 10px; font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase; color: #B8975A; margin-bottom: 14px; }
  .ag__h2 { font-size: clamp(24px, 3.5vw, 34px); font-weight: 400; color: #1C1A18; line-height: 1.2; margin-bottom: 20px; letter-spacing: -0.01em; }
  .ag__h2--intro { font-size: clamp(20px, 2.8vw, 28px); }
  .ag__section p { font-size: 15px; font-weight: 300; color: #5A5450; line-height: 1.85; margin-bottom: 16px; }
  .ag__section em { color: #B8975A; font-style: italic; }

  .ag__benefits { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(184,151,90,0.15); border: 1px solid rgba(184,151,90,0.2); border-radius: 8px; overflow: hidden; margin: 32px 0 40px; }
  .ag__benefit { background: #FAF7F2; padding: 28px 22px; transition: background 0.2s; }
  .ag__benefit:hover { background: #F0EBE1; }
  .ag__benefit-icon { width: 32px; height: 32px; margin-bottom: 14px; }
  .ag__benefit h4 { font-size: 15px; font-weight: 500; color: #1C1A18; margin-bottom: 8px; }
  .ag__benefit p { font-size: 13px !important; color: #8A837A !important; line-height: 1.6 !important; margin: 0 !important; }

  .ag__table-wrap { margin: 28px 0 36px; border: 1px solid rgba(184,151,90,0.25); border-radius: 8px; overflow: hidden; }
  .ag__table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .ag__table thead { background: #1C1A18; }
  .ag__table thead th { padding: 13px 18px; text-align: left; font-weight: 400; letter-spacing: 0.1em; font-size: 10px; text-transform: uppercase; color: rgba(250,247,242,0.7); }
  .ag__table tbody tr { border-bottom: 1px solid rgba(184,151,90,0.15); }
  .ag__table tbody tr:last-child { border-bottom: none; }
  .ag__table-row--highlight { background: rgba(184,151,90,0.06); }
  .ag__table td { padding: 13px 18px; color: #5A5450; vertical-align: middle; }
  .ag__table-name { color: #1C1A18 !important; font-weight: 500; }
  .ag__badge { display: inline-block; padding: 2px 8px; background: #B8975A; color: #fff; font-size: 9px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; border-radius: 4px; margin-left: 6px; vertical-align: middle; }

  .ag__quote { border-left: 2px solid #B8975A; padding: 16px 0 16px 28px; margin: 32px 0 52px; }
  .ag__quote p { font-size: 19px !important; font-weight: 300 !important; font-style: italic; color: #3A3733 !important; line-height: 1.6 !important; margin: 0 !important; font-family: Georgia, serif; }

  .ag__scale { margin: 32px 0 36px; }
  .ag__scale-track { height: 5px; background: #E8E2D8; border-radius: 3px; position: relative; margin-bottom: 40px; }
  .ag__scale-fill { position: absolute; left: 0; top: 0; height: 100%; width: 73%; background: linear-gradient(to right, #D4B07A, #B8975A); border-radius: 3px; }
  .ag__scale-marker { position: absolute; top: -5px; transform: translateX(-50%); text-align: center; }
  .ag__scale-dot { width: 15px; height: 15px; border-radius: 50%; border: 2px solid #FAF7F2; background: #8A837A; margin: 0 auto 10px; }
  .ag__scale-marker--active .ag__scale-dot { background: #B8975A; border-color: #B8975A; box-shadow: 0 0 0 4px rgba(184,151,90,0.2); }
  .ag__scale-val { font-size: 13px; font-weight: 500; color: #8A837A; white-space: nowrap; }
  .ag__scale-marker--active .ag__scale-val { color: #B8975A; }
  .ag__scale-lbl { font-size: 10px; color: #AAA49E; letter-spacing: 0.05em; white-space: nowrap; margin-top: 3px; }

  .ag__plus { background: rgba(184,151,90,0.06); border: 1px solid rgba(184,151,90,0.2); border-radius: 8px; padding: 24px 28px; margin: 0 0 52px; }
  .ag__plus-label { font-size: 10px; font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: #B8975A; margin-bottom: 12px; }
  .ag__plus p { font-size: 14px !important; color: #5A5450 !important; line-height: 1.8 !important; margin: 0 !important; }

  /* ── FAQ ─────────────────────────────────────────────── */
  .ag__faq { margin: 28px 0 52px; border-top: 1px solid rgba(184,151,90,0.2); }
  .ag__faq-item { padding: 24px 0; border-bottom: 1px solid rgba(184,151,90,0.15); }
  .ag__faq-q {
    font-size: 15px; font-weight: 600; color: #1C1A18;
    line-height: 1.4; margin: 0 0 10px;
    padding-left: 20px;
    position: relative;
  }
  .ag__faq-q::before {
    content: '✦';
    position: absolute; left: 0; top: 1px;
    font-size: 9px; color: #B8975A; line-height: 1.6;
  }
  .ag__faq-a { font-size: 14px; font-weight: 300; color: #5A5450; line-height: 1.8; margin: 0; padding-left: 20px; }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .ag__rte table thead th:nth-child(3),
    .ag__rte table td:nth-child(3) { display: none; }
    .ag__cta-specs { gap: 24px; }
    .ag__hero { padding-bottom: 48px; }
    .ag__body { padding: 0 20px; }
    .ag__featured-img-wrap { padding: 0 16px; margin-top: -24px; }
  }
</style>

<script>
(function() {
  function buildFAQSchema() {
    var qs = document.querySelectorAll('.ag__faq-q');
    var as = document.querySelectorAll('.ag__faq-a');
    if (!qs.length) return;
    var entities = [];
    for (var i = 0; i < qs.length; i++) {
      if (!as[i]) continue;
      entities.push({
        "@type": "Question",
        "name": qs[i].textContent.trim(),
        "acceptedAnswer": { "@type": "Answer", "text": as[i].textContent.trim() }
      });
    }
    if (!entities.length) return;
    var s = document.createElement('script');
    s.type = 'application/ld+json';
    s.textContent = JSON.stringify({ "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": entities });
    document.head.appendChild(s);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', buildFAQSchema);
  } else {
    buildFAQSchema();
  }
})();
</script>

{% schema %}
{
  "name": "Article Guide Masque",
  "settings": [],
  "presets": [{ "name": "Article Guide Masque" }]
}
{% endschema %}
