{% comment %} Article — Andromeda style — dark hero / light body / dark CTA {% endcomment %}

<div class="aa" id="aa">

  <!-- ── HERO (dark) ──────────────────────────────────────────────────── -->
  <header class="aa__hero">
    <div class="aa__hero-bg" aria-hidden="true">
      <div class="aa__stars aa__stars--1"></div>
      <div class="aa__stars aa__stars--2"></div>
    </div>

    <div class="aa__hero-inner">
      {%- render 'breadcrumbs', color: 'light' -%}
      <a href="{{ blog.url }}" class="aa__back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 3L4 7L9 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ blog.title }}
      </a>

      <div class="aa__meta">
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: '%d %B %Y' }}
        </time>
        {% if article.tags.size > 0 %}
          {% for tag in article.tags %}
            <span class="aa__tag">{{ tag }}</span>
          {% endfor %}
        {% endif %}
      </div>

      <h1 class="aa__title">{{ article.title }}</h1>

      {% if article.excerpt != blank %}
        <p class="aa__excerpt">{{ article.excerpt | strip_html }}</p>
      {% endif %}

      <div class="aa__author">
        <span class="aa__author-avatar" aria-hidden="true">A</span>
        <div>
          <span class="aa__author-name">L'équipe Andromeda Paris</span>
          <span class="aa__author-bio">Spécialistes du sommeil &amp; de la soie de mûrier</span>
        </div>
      </div>
    </div>
  </header>

  <!-- ── BODY (light) ─────────────────────────────────────────────────── -->
  <div class="aa__body">

    {% if article.image %}
      <div class="aa__img-wrap">
        <img
          src="{{ article.image | image_url: width: 1400 }}"
          alt="{{ article.image.alt | default: article.title | escape }}"
          class="aa__img"
          loading="eager"
          width="{{ article.image.width }}"
          height="{{ article.image.height }}"
        >
      </div>
    {% endif %}

    <div class="aa__content rte">
      {{ article.content }}
    </div>

    {% if article.tags.size > 0 %}
      <div class="aa__tags-footer">
        <span class="aa__tags-label">Tags</span>
        <div class="aa__tags-list">
          {% for tag in article.tags %}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="aa__tag-link">{{ tag }}</a>
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>

  <!-- ── CTA (dark) ───────────────────────────────────────────────────── -->
  <div class="aa__cta">
    <div class="aa__cta-bg" aria-hidden="true">
      <div class="aa__stars aa__stars--1"></div>
      <div class="aa__stars aa__stars--2"></div>
    </div>
    <div class="aa__cta-inner">
      <p class="aa__cta-label">Journal Andromeda</p>
      <a href="{{ blog.url }}" class="aa__cta-btn">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 3L4 7L9 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Retour au journal
      </a>
    </div>
  </div>

</div>

<style>
  @font-face {
    font-family: 'Stellar';
    src: url('https://cdn.shopify.com/s/files/1/1000/9375/5727/files/MirageStellar.ttf?v=1772405200') format('opentype');
    font-weight: normal; font-style: normal; font-display: swap;
  }

  /* ── Stars ─────────────────────────────────────────────── */
  .aa__stars { position: absolute; inset: 0; }
  .aa__stars--1 {
    background-image:
      radial-gradient(1.2px 1.2px at 8% 15%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(1px 1px at 22% 72%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 38% 28%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 52% 85%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.3px 1.3px at 67% 10%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(0.9px 0.9px at 78% 55%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.4px 1.4px at 91% 38%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 14% 90%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 45% 50%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(1.1px 1.1px at 85% 80%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1.4px 1.4px at 55% 5%, rgba(255,255,255,0.65) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 95% 20%, rgba(255,255,255,0.6) 0%, transparent 100%);
    animation: aa-drift-1 35s ease-in-out infinite;
  }
  .aa__stars--2 {
    background-image:
      radial-gradient(1px 1px at 12% 25%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.3px 1.3px at 35% 60%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(0.9px 0.9px at 58% 18%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.2px 1.2px at 74% 42%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(0.8px 0.8px at 48% 75%, rgba(255,255,255,0.4) 0%, transparent 100%);
    animation: aa-drift-2 50s ease-in-out infinite; opacity: 0.7;
  }
  @keyframes aa-drift-1 {
    0%, 100% { transform: translate(0,0); } 33% { transform: translate(-10px,-7px); } 66% { transform: translate(7px,-12px); }
  }
  @keyframes aa-drift-2 {
    0%, 100% { transform: translate(0,0); } 40% { transform: translate(9px,-5px); } 70% { transform: translate(-7px,9px); }
  }

  /* ── Hero ──────────────────────────────────────────────── */
  .aa__hero {
    position: relative; background: #191A2E; overflow: hidden;
    padding-bottom: 80px;
  }
  .aa__hero-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .aa__hero > *:not(.aa__hero-bg) { position: relative; z-index: 1; }
  .aa__hero-inner { max-width: 700px; margin: 0 auto; padding: 48px 24px 0; text-align: center; }

  .aa__back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 10px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); text-decoration: none; transition: color 0.2s;
    margin-bottom: 40px;
  }
  .aa__back:hover { color: #C8B89A; }

  .aa__meta {
    display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 10px;
    font-size: 10px; font-weight: 300; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 20px;
  }
  .aa__tag {
    color: #C8B89A; border: 1px solid rgba(200,184,154,0.3);
    border-radius: 20px; padding: 2px 10px; font-size: 9px;
  }

  #aa .aa__title, .aa__title {
    font-family: 'Stellar', serif !important;
    font-size: clamp(32px, 5vw, 56px) !important;
    font-weight: normal !important; color: #FFFFFF !important;
    word-spacing: -0.22em !important; letter-spacing: 0 !important;
    line-height: 1.1 !important; margin-bottom: 20px;
  }
  .aa__excerpt {
    font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.5);
    line-height: 1.75; max-width: 500px; margin: 0 auto 28px;
  }
  .aa__author {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 4px;
  }
  .aa__author-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(200,184,154,0.15); border: 1px solid rgba(200,184,154,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 600; color: #C8B89A;
    flex-shrink: 0;
  }
  .aa__author-name {
    display: block; font-size: 11px; font-weight: 500;
    color: rgba(255,255,255,0.7); letter-spacing: 0.04em;
  }
  .aa__author-bio {
    display: block; font-size: 10px; font-weight: 300;
    color: rgba(255,255,255,0.3); letter-spacing: 0.04em; margin-top: 2px;
  }

  /* ── Body ──────────────────────────────────────────────── */
  .aa__body {
    background: #FAF7F2; color: #3A3733;
    max-width: 720px; margin: 0 auto;
    padding: 56px 24px 72px;
  }

  .aa__img-wrap {
    border-radius: 16px; overflow: hidden; margin-bottom: 48px; aspect-ratio: 16/9;
  }
  .aa__img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* RTE content */
  .aa__content.rte {
    font-size: 15px; font-weight: 300; line-height: 1.85; color: #3A3733;
  }
  .aa__content.rte h2,
  .aa__content.rte h3,
  .aa__content.rte h4 {
    color: #1C1A18; font-weight: 500; margin-top: 48px; margin-bottom: 16px; line-height: 1.3;
  }
  .aa__content.rte h2 { font-size: 22px; }
  .aa__content.rte h3 { font-size: 18px; }
  .aa__content.rte h4 { font-size: 15px; }
  .aa__content.rte p { margin-bottom: 22px; }
  .aa__content.rte a { color: #B8975A; text-decoration: underline; text-underline-offset: 3px; }
  .aa__content.rte a:hover { color: #1C1A18; }
  .aa__content.rte img { width: 100%; border-radius: 12px; margin: 32px 0; display: block; }
  .aa__content.rte blockquote {
    border-left: 2px solid #B8975A; padding-left: 20px; margin: 32px 0;
    font-style: italic; color: #8A837A;
  }
  .aa__content.rte ul,
  .aa__content.rte ol { padding-left: 20px; margin-bottom: 22px; }
  .aa__content.rte li { margin-bottom: 8px; }
  .aa__content.rte hr {
    border: none; border-top: 1px solid rgba(184,151,90,0.2); margin: 40px 0;
  }

  /* Tags footer */
  .aa__tags-footer {
    margin-top: 56px; padding-top: 28px;
    border-top: 1px solid rgba(184,151,90,0.15);
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  }
  .aa__tags-label {
    font-size: 10px; font-weight: 400; letter-spacing: 0.2em;
    text-transform: uppercase; color: #AAA49E;
  }
  .aa__tags-list { display: flex; flex-wrap: wrap; gap: 8px; }
  .aa__tag-link {
    font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: #AAA49E; text-decoration: none;
    border: 1px solid rgba(184,151,90,0.2); border-radius: 20px; padding: 4px 12px;
    transition: color 0.2s, border-color 0.2s;
  }
  .aa__tag-link:hover { color: #B8975A; border-color: rgba(184,151,90,0.5); }

  /* ── CTA ───────────────────────────────────────────────── */
  .aa__cta {
    position: relative; background: #191A2E; overflow: hidden;
    text-align: center; padding: 80px 24px;
  }
  .aa__cta-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .aa__cta > *:not(.aa__cta-bg) { position: relative; z-index: 1; }
  .aa__cta-inner { max-width: 480px; margin: 0 auto; }

  .aa__cta-label {
    font-size: 10px; font-weight: 400; letter-spacing: 0.4em; text-transform: uppercase;
    color: #C8B89A; margin-bottom: 24px;
  }
  .aa__cta-btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase;
    color: #C8B89A; text-decoration: none;
    border: 1px solid rgba(200,184,154,0.3); padding: 14px 28px; border-radius: 40px;
    transition: background 0.2s, gap 0.2s;
  }
  .aa__cta-btn:hover { background: rgba(200,184,154,0.08); gap: 12px; }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 640px) {
    .aa__hero-inner { padding-top: 36px; }
    .aa__body { padding: 40px 20px 56px; }
  }
</style>

{% schema %}
{
  "name": "Article Andromeda",
  "settings": [],
  "presets": [{ "name": "Article Andromeda" }]
}
{% endschema %}
