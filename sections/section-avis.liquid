{% assign total_reviews = 5 %}
{% assign avg_rating = 5.0 %}

<section class="andromeda-avis">

  <h2 class="andromeda-avis__title">Avis vérifiés</h2>

  <div class="andromeda-avis__header">
    <div class="andromeda-avis__summary">
      <div class="andromeda-avis__score-block">
        <div class="andromeda-avis__score">
          <span class="andromeda-avis__score-num">5.0</span>
          <span class="andromeda-avis__score-max">/ 5</span>
        </div>
        <div class="andromeda-avis__stars" aria-label="5 sur 5">★★★★★</div>
        <p class="andromeda-avis__count">Basé sur {{ total_reviews }} avis vérifiés</p>
      </div>
      <div class="andromeda-avis__bars">
        <div class="andromeda-avis__bar-row">
          <span class="andromeda-avis__bar-label">5 ★</span>
          <div class="andromeda-avis__bar-track"><div class="andromeda-avis__bar-fill" style="width:100%"></div></div>
          <span class="andromeda-avis__bar-count">5</span>
        </div>
        <div class="andromeda-avis__bar-row">
          <span class="andromeda-avis__bar-label">4 ★</span>
          <div class="andromeda-avis__bar-track"><div class="andromeda-avis__bar-fill" style="width:0%"></div></div>
          <span class="andromeda-avis__bar-count">0</span>
        </div>
        <div class="andromeda-avis__bar-row">
          <span class="andromeda-avis__bar-label">3 ★</span>
          <div class="andromeda-avis__bar-track"><div class="andromeda-avis__bar-fill" style="width:0%"></div></div>
          <span class="andromeda-avis__bar-count">0</span>
        </div>
        <div class="andromeda-avis__bar-row">
          <span class="andromeda-avis__bar-label">2 ★</span>
          <div class="andromeda-avis__bar-track"><div class="andromeda-avis__bar-fill" style="width:0%"></div></div>
          <span class="andromeda-avis__bar-count">0</span>
        </div>
        <div class="andromeda-avis__bar-row">
          <span class="andromeda-avis__bar-label">1 ★</span>
          <div class="andromeda-avis__bar-track"><div class="andromeda-avis__bar-fill" style="width:0%"></div></div>
          <span class="andromeda-avis__bar-count">0</span>
        </div>
      </div>
    </div>
    <a href="mailto:contact@andromedaparis.com?subject=Laisser un avis" class="andromeda-avis__cta">Rédiger un avis</a>
  </div>

  <div class="andromeda-avis__divider"></div>

  <div class="andromeda-avis__list">

    <div class="andromeda-avis__item">
      <div class="andromeda-avis__item-top">
        <div class="andromeda-avis__item-author">
          Julie Julie
          <span class="andromeda-avis__verified">Vérifié</span>
        </div>
        <span class="andromeda-avis__date">12/01/2026</span>
      </div>
      <div class="andromeda-avis__item-stars">★★★★★</div>
      <p class="andromeda-avis__item-title">Top produit ! Nécessaire pour votre rituel beauté !</p>
      <p class="andromeda-avis__item-text">Le produit est magnifique, la texture est douce, ça se voit que la soie est d'une haute qualité ! Très agréable pour les yeux ! Je recommande vivement !</p>
    </div>

    <div class="andromeda-avis__item">
      <div class="andromeda-avis__item-top">
        <div class="andromeda-avis__item-author">
          Arbi Ben Ali
          <span class="andromeda-avis__verified">Vérifié</span>
        </div>
        <span class="andromeda-avis__date">05/01/2026</span>
      </div>
      <div class="andromeda-avis__item-stars">★★★★★</div>
      <p class="andromeda-avis__item-title">Masque confortable et de qualité</p>
      <p class="andromeda-avis__item-text">Qualité du produit remarquable, ça vaut largement son prix. Soie très douce et lisse. Je me lève le matin avec un regard frais et reposé. Je pense qu'il me servira encore de nombreuses années.</p>
    </div>

    <div class="andromeda-avis__item">
      <div class="andromeda-avis__item-top">
        <div class="andromeda-avis__item-author">
          Viktoriia Nechiporenko
          <span class="andromeda-avis__verified">Vérifié</span>
        </div>
        <span class="andromeda-avis__date">28/12/2025</span>
      </div>
      <div class="andromeda-avis__item-stars">★★★★★</div>
      <p class="andromeda-avis__item-title">Bon rapport qualité / prix</p>
      <p class="andromeda-avis__item-text">La matière est belle, soie naturelle, c'est très différent de mon masque synthétique précédent ! Masque bien large pour protéger les yeux de la lumière, confortable et doux sur le visage. Reçu avec un bel emballage cadeau. J'adore.</p>
    </div>

    <div class="andromeda-avis__item">
      <div class="andromeda-avis__item-top">
        <div class="andromeda-avis__item-author">
          Kristina Gobova
          <span class="andromeda-avis__verified">Vérifié</span>
        </div>
        <span class="andromeda-avis__date">18/12/2025</span>
      </div>
      <div class="andromeda-avis__item-stars">★★★★★</div>
      <p class="andromeda-avis__item-title">Très bonne qualité</p>
      <p class="andromeda-avis__item-text">Masque très confortable et doux, agréable sur la peau. Soie naturelle avec un joli éclat, et la boîte est un vrai coup de cœur.</p>
    </div>

    <div class="andromeda-avis__item">
      <div class="andromeda-avis__item-top">
        <div class="andromeda-avis__item-author">
          Jean Moreau
          <span class="andromeda-avis__verified">Vérifié</span>
        </div>
        <span class="andromeda-avis__date">02/12/2025</span>
      </div>
      <div class="andromeda-avis__item-stars">★★★★★</div>
      <p class="andromeda-avis__item-title">Excellent produit</p>
      <p class="andromeda-avis__item-text">Taille parfaite, très confortable aussi bien pour moi que pour ma femme. Excellent rapport qualité-prix.</p>
    </div>

  </div>

</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap');

  .andromeda-avis,
  .andromeda-avis * {
    font-family: 'Raleway', sans-serif !important;
    max-width: unset;
  }
  .andromeda-avis {
    max-width: 860px;
    margin: 0 auto;
    padding: 64px 24px;
  }

  .andromeda-avis__title {
    font-family: 'Raleway', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
    color: #1C1A18;
    margin-bottom: 40px;
  }

  /* ── Header summary ──────────────────────────────────── */
  .andromeda-avis__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 40px;
  }

  .andromeda-avis__summary {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 40px;
  }

  .andromeda-avis__score-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-shrink: 0;
  }

  .andromeda-avis__score {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .andromeda-avis__score-num {
    font-size: 40px;
    font-weight: 700;
    color: #1C1A18;
    line-height: 1;
  }
  .andromeda-avis__score-max {
    font-size: 16px;
    font-weight: 400;
    color: #1C1A18;
    opacity: 0.4;
  }

  .andromeda-avis__stars {
    color: #B8975A;
    font-size: 18px;
    letter-spacing: 2px;
  }

  .andromeda-avis__count {
    font-size: 12px;
    font-weight: 400;
    color: #1C1A18;
    opacity: 0.45;
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* ── Barres ──────────────────────────────────────────── */
  .andromeda-avis__bars {
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-top: 4px;
  }
  .andromeda-avis__bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .andromeda-avis__bar-label {
    font-size: 11px;
    color: #1C1A18;
    opacity: 0.5;
    width: 28px;
    flex-shrink: 0;
  }
  .andromeda-avis__bar-track {
    width: 140px;
    height: 4px;
    background: rgba(28,26,24,0.1);
    border-radius: 2px;
    overflow: hidden;
  }
  .andromeda-avis__bar-fill {
    height: 100%;
    background: #B8975A;
    border-radius: 2px;
  }
  .andromeda-avis__bar-count {
    font-size: 11px;
    color: #1C1A18;
    opacity: 0.4;
    width: 16px;
  }

  /* ── CTA ─────────────────────────────────────────────── */
  .andromeda-avis__cta {
    display: inline-block;
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background: #1C1A18;
    border: none;
    padding: 14px 24px;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease;
  }
  .andromeda-avis__cta:hover {
    background: #B8975A;
  }

  /* ── Divider ─────────────────────────────────────────── */
  .andromeda-avis__divider {
    height: 1px;
    background: rgba(28,26,24,0.1);
    margin-bottom: 0;
  }

  /* ── Liste des avis ──────────────────────────────────── */
  .andromeda-avis__list {
    display: flex;
    flex-direction: column;
  }

  .andromeda-avis__item {
    padding: 28px 0;
    border-bottom: 1px solid rgba(28,26,24,0.1);
  }

  .andromeda-avis__item-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .andromeda-avis__item-author {
    font-size: 13px;
    font-weight: 600;
    color: #1C1A18;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .andromeda-avis__verified {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: #1C1A18;
    padding: 2px 7px;
    border-radius: 2px;
  }

  .andromeda-avis__date {
    font-size: 11px;
    color: #1C1A18;
    opacity: 0.35;
  }

  .andromeda-avis__item-stars {
    color: #B8975A;
    font-size: 14px;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .andromeda-avis__item-title {
    font-size: 13px;
    font-weight: 700;
    color: #1C1A18;
    margin: 0 0 6px;
    line-height: 1.4;
  }

  .andromeda-avis__item-text {
    font-size: 13px;
    font-weight: 400;
    color: #1C1A18;
    opacity: 0.65;
    margin: 0;
    line-height: 1.7;
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 600px) {
    .andromeda-avis__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }
    .andromeda-avis__summary { gap: 20px; }
    .andromeda-avis__bar-track { width: 80px; }
    .andromeda-avis__cta { width: 100%; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "Avis clients",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Couleur de fond",
      "default": "scheme-1"
    }
  ],
  "presets": [{"name": "Avis clients"}]
}
{% endschema %}
