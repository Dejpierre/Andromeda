{% if section.blocks.size > 0 %}
<div class="spb" style="background: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;">
  <div class="spb__grid">
    {% for block in section.blocks %}
      {% if block.type == 'avantage' %}
        <div class="spb__item" {{ block.shopify_attributes }}>
          <div class="spb__icon">
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | image_url: width: 40 }}" alt="{{ block.settings.label }}" width="20" height="20">
            {% else %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            {% endif %}
          </div>
          <div class="spb__text">
            {% if block.settings.label != blank %}
              <span class="spb__label">{{ block.settings.label }}</span>
            {% endif %}
            {% if block.settings.desc != blank %}
              <span class="spb__desc">{{ block.settings.desc }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

<style>
.spb {
  width: 100%;
}
.spb__grid {
  max-width: 560px;
  margin: 0 auto 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px 28px;
}
.spb__item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
.spb__icon {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid #B8975A;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #B8975A;
  margin-top: 2px;
  position: relative;
}
.spb__icon img {
  width: {{ section.settings.icon_size | default: '20px' }};
  height: {{ section.settings.icon_size | default: '20px' }};
  object-fit: contain;
}
.spb__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.spb__label {
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.03em;
  color: #1C1A18;
}
.spb__desc {
  font-size: 0.75rem;
  color: #1C1A18;
  opacity: 0.6;
  line-height: 1.4;
}
@media (max-width: 749px) {
  .spb__grid {
    max-width: 100%;
  }
}

/* Cascade animation */
.spb--ready .spb__item {
  opacity: 0;
  transform: translateY(14px);
}
.spb--ready .spb__item.spb--visible {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.spb--ready .spb__item.spb--visible .spb__icon {
  animation: spb-star-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
.spb--ready .spb__item.spb--visible .spb__label {
  animation: spb-fade-slide 0.4s ease both;
  animation-delay: 0.08s;
}
.spb--ready .spb__item.spb--visible .spb__desc {
  animation: spb-fade-slide 0.4s ease both;
  animation-delay: 0.14s;
}

@keyframes spb-star-pop {
  0%   { transform: scale(0.3) rotate(-15deg); opacity: 0; }
  60%  { transform: scale(1.15) rotate(5deg); opacity: 1; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}
@keyframes spb-fade-slide {
  from { opacity: 0; transform: translateX(-6px); }
  to   { opacity: 1; transform: translateX(0); }
}
</style>

<script>
(function () {
  var grid = document.querySelector('.spb__grid');
  if (!grid) return;
  grid.classList.add('spb--ready');
  var items = Array.from(grid.querySelectorAll('.spb__item'));

  var observer = new IntersectionObserver(function (entries) {
    if (!entries[0].isIntersecting) return;
    items.forEach(function (item, i) {
      setTimeout(function () {
        item.classList.add('spb--visible');
      }, i * 130);
    });
    observer.disconnect();
  }, { threshold: 0.25 });

  observer.observe(grid);
})();
</script>

{% schema %}
{
  "name": "Avantages produit",
  "tag": "div",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "icon_size",
      "label": "Taille des icônes",
      "info": "Ex: 20px ou 8%",
      "default": "20px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espacement haut",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espacement bas",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "avantage",
      "name": "Avantage",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icône (optionnel)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Titre",
          "default": "Avantage"
        },
        {
          "type": "textarea",
          "id": "desc",
          "label": "Description",
          "default": "Description de l'avantage"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avantages produit",
      "blocks": [
        {
          "type": "avantage",
          "settings": {
            "label": "Soie Grade 6A",
            "desc": "Moins de 5 % de la production mondiale"
          }
        },
        {
          "type": "avantage",
          "settings": {
            "label": "Obscurité totale",
            "desc": "Blocage 100 % de la lumière"
          }
        },
        {
          "type": "avantage",
          "settings": {
            "label": "22 mommes",
            "desc": "Grammage optimal pour la peau"
          }
        },
        {
          "type": "avantage",
          "settings": {
            "label": "Peau & cheveux",
            "desc": "Anti-friction, hydratation naturelle"
          }
        }
      ]
    }
  ]
}
{% endschema %}
