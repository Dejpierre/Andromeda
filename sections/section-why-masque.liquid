{% comment %} Section Pourquoi choisir — image centrale + 4 avantages {% endcomment %}

<div class="wm" id="wm">

  {% if section.settings.title != blank or section.settings.title_accent != blank %}
    <div class="wm__header">
      <h2 class="wm__title">
        {{ section.settings.title }}
        {% if section.settings.title_accent != blank %}
          <em>{{ section.settings.title_accent }}</em>
        {% endif %}
      </h2>
      {% if section.settings.subtitle != blank %}
        <p class="wm__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="wm__inner">

    {% assign blocks_left  = '' %}
    {% assign blocks_right = '' %}
    {% assign idx = 0 %}

    <div class="wm__col wm__col--left">
      {% for block in section.blocks %}
        {% assign idx = forloop.index0 %}
        {% if idx == 0 or idx == 1 %}
          <div class="wm__item" {{ block.shopify_attributes }}>
            <div class="wm__icon-wrap">
              {% if block.settings.icon != blank %}
                <img src="{{ block.settings.icon | image_url: width: 64 }}" alt="{{ block.settings.title | default: 'Icône bénéfice Andromeda' | escape }}" class="wm__icon-img" width="32" height="32">
              {% else %}
                <svg class="wm__icon-svg" viewBox="0 0 32 32" fill="none" width="32" height="32">
                  <circle cx="16" cy="16" r="10" stroke="#B8975A" stroke-width="1.2"/>
                  <circle cx="16" cy="16" r="3" fill="#B8975A" opacity="0.5"/>
                </svg>
              {% endif %}
            </div>
            <h3 class="wm__item-title">{{ block.settings.title }}</h3>
            <p class="wm__item-text">{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="wm__visual">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          class="wm__img"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {% else %}
        <div class="wm__img-placeholder">{{ 'product-1' | placeholder_svg_tag: 'wm__placeholder-svg' }}</div>
      {% endif %}
    </div>

    <div class="wm__col wm__col--right">
      {% for block in section.blocks %}
        {% assign idx = forloop.index0 %}
        {% if idx == 2 or idx == 3 %}
          <div class="wm__item" {{ block.shopify_attributes }}>
            <div class="wm__icon-wrap">
              {% if block.settings.icon != blank %}
                <img src="{{ block.settings.icon | image_url: width: 64 }}" alt="{{ block.settings.title | default: 'Icône bénéfice Andromeda' | escape }}" class="wm__icon-img" width="32" height="32">
              {% else %}
                <svg class="wm__icon-svg" viewBox="0 0 32 32" fill="none" width="32" height="32">
                  <circle cx="16" cy="16" r="10" stroke="#B8975A" stroke-width="1.2"/>
                  <circle cx="16" cy="16" r="3" fill="#B8975A" opacity="0.5"/>
                </svg>
              {% endif %}
            </div>
            <h3 class="wm__item-title">{{ block.settings.title }}</h3>
            <p class="wm__item-text">{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>

  {% if section.settings.heading != blank %}
    <p class="wm__heading-label">{{ section.settings.heading }}</p>
  {% endif %}
</div>

<style>
  @font-face {
    font-family: 'Stellar';
    src: url('https://cdn.shopify.com/s/files/1/1000/9375/5727/files/MirageStellar.ttf?v=1772405200') format('opentype');
    font-weight: normal; font-style: normal; font-display: swap;
  }

  .wm {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
  }

  .wm__header {
    max-width: 1440px;
    margin: 0 auto 48px;
    text-align: center;
  }
  .wm__title {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .wm__title em {
    font-family: 'Stellar', serif;
    font-style: normal;
  }
  .wm__subtitle {
    font-size: 14px;
    font-weight: 300;
    color: {{ section.settings.text_color }};
    opacity: 0.55;
    line-height: 1.7;
    max-width: 460px;
    margin: 0 auto;
  }

  .wm__inner {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr {{ section.settings.image_width }}% 1fr;
    gap: 60px;
    align-items: center;
  }

  /* ── Columns ───────────────────────────────────────────── */
  .wm__col {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  .wm__col--left { text-align: right; align-items: flex-end; }
  .wm__col--right { text-align: left; align-items: flex-start; }

  /* ── Item ──────────────────────────────────────────────── */
  .wm__item { max-width: 260px; }

  .wm__icon-wrap {
    width: 44px; height: 44px;
    border: 1px solid rgba(184,151,90,0.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px;
  }
  .wm__col--left .wm__icon-wrap { margin-left: auto; }

  .wm__icon-svg, .wm__icon-img { width: 20px; height: 20px; }

  .wm__item-title {
    font-size: 15px;
    font-weight: 500;
    color: {{ section.settings.text_color }};
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .wm__item-text {
    font-size: 13px;
    font-weight: 300;
    color: {{ section.settings.text_color }};
    opacity: 0.65;
    line-height: 1.65;
    margin: 0;
  }

  /* ── Visual ────────────────────────────────────────────── */
  .wm__visual {
    width: 100%;
    flex-shrink: 0;
    aspect-ratio: {{ section.settings.image_ratio }};
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
  }
  .wm__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: {{ section.settings.image_radius }}px;
  }
  .wm__img-placeholder {
    width: 100%; height: 100%;
    background: rgba(184,151,90,0.08);
    display: flex; align-items: center; justify-content: center;
  }
  .wm__placeholder-svg { width: 60%; opacity: 0.2; }

  /* ── Optional label ────────────────────────────────────── */
  .wm__heading-label {
    text-align: center;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #B8975A;
    margin: 40px auto 0;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .wm__inner {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      gap: 32px;
    }
    .wm__visual { width: 100%; max-width: 320px; margin: 0 auto; }
    .wm__col--left,
    .wm__col--right {
      text-align: left;
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 24px;
    }
    .wm__col--left .wm__icon-wrap { margin-left: 0; }
    .wm__item { max-width: calc(50% - 12px); min-width: 200px; flex: 1; }
  }
  @media (max-width: 480px) {
    .wm__col--left,
    .wm__col--right { flex-direction: column; }
    .wm__item { max-width: 100%; }
  }
</style>

{% schema %}
{
  "name": "Pourquoi nos masques",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre — partie normale",
      "default": "Pourquoi choisir"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Titre — mot en Stellar (doré)",
      "default": "nos masques ?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre (optionnel)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image produit (centre)"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Largeur de l'image",
      "min": 20, "max": 60, "step": 2, "default": 36,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format de l'image",
      "options": [
        { "value": "1/1",  "label": "Carré (1:1)" },
        { "value": "4/3",  "label": "Paysage (4:3)" },
        { "value": "3/2",  "label": "Paysage (3:2)" },
        { "value": "16/9", "label": "Cinémascope (16:9)" },
        { "value": "3/4",  "label": "Portrait (3:4)" }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Arrondi image",
      "min": 0, "max": 40, "step": 2, "default": 16
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Label optionnel sous la section"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#FAF7F2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#1C1A18"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espacement haut",
      "min": 0, "max": 120, "step": 8, "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espacement bas",
      "min": 0, "max": 120, "step": 8, "default": 80
    }
  ],
  "blocks": [
    {
      "type": "avantage",
      "name": "Avantage",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icône (optionnel)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Avantage"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Décrivez cet avantage en une ou deux phrases."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pourquoi nos masques",
      "blocks": [
        { "type": "avantage", "settings": { "title": "Soie Grade 6A", "text": "Moins de 5% de la production mondiale. Filaments extra-longs pour une douceur incomparable." } },
        { "type": "avantage", "settings": { "title": "22 mommes", "text": "Le grammage optimal : opacité totale et légèreté pour une nuit sans compromis." } },
        { "type": "avantage", "settings": { "title": "Obscurité totale", "text": "Conçu pour bloquer 100% de la lumière et maximiser la production de mélatonine." } },
        { "type": "avantage", "settings": { "title": "Peau & cheveux", "text": "Anti-friction, hydratant naturel. La soie préserve là où le coton absorbe." } }
      ]
    }
  ]
}
{% endschema %}
