<div style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
    {{ section.blocks | map: 'settings' | map: 'text' | join: '' }}
  </div>
</div>

{% schema %}
{
  "name": "SEO Text",
  "settings": [
    {"type": "color", "id": "bg_color", "label": "Couleur fond", "default": "#FAFAF8"},
    {"type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "label": "Padding haut", "default": 40},
    {"type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "label": "Padding bas", "default": 40}
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Texte SEO",
      "settings": [
        {"type": "html", "id": "text", "label": "Contenu"}
      ]
    }
  ],
  "max_blocks": 1,
  "presets": [{"name": "SEO Text"}]
}
{% endschema %}