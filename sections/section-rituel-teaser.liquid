<section class="rituel-teaser">

  <!-- Fond étoilé -->
  <div class="rituel-teaser__bg" aria-hidden="true">
    <div class="rituel-teaser__moon-glow"></div>
    <div class="rituel-teaser__stars"></div>
    <div class="rituel-teaser__stars-2"></div>
  </div>

  <div class="rituel-teaser__inner page-width">

    <div class="rituel-teaser__badge">✦ Exclusif clients</div>

    <h2 class="rituel-teaser__title">Le rituel sonore Andromeda</h2>
    <p class="rituel-teaser__subtitle">
      Chaque masque est livré avec un accès exclusif à notre espace rituel.<br>
      Sons d'ambiance, pluie nocturne, vagues, méditation guidée — une expérience sensorielle pour transformer chaque nuit.
    </p>

    <div class="rituel-teaser__sounds">
      <div class="rituel-teaser__sound-item">
        <span class="rituel-teaser__sound-icon">🌧</span>
        <span>Pluie sur Paris</span>
      </div>
      <div class="rituel-teaser__sound-item">
        <span class="rituel-teaser__sound-icon">🌊</span>
        <span>Vagues de l'océan</span>
      </div>
      <div class="rituel-teaser__sound-item">
        <span class="rituel-teaser__sound-icon">🌿</span>
        <span>Forêt la nuit</span>
      </div>
      <div class="rituel-teaser__sound-item">
        <span class="rituel-teaser__sound-icon">🎙</span>
        <span>Endormissement guidé</span>
      </div>
    </div>

    <a href="/products" class="rituel-teaser__cta btn btn--primary">
      Découvrir le masque
    </a>

    <p class="rituel-teaser__mention">Accès via QR code inclus dans chaque commande</p>

  </div>

</section>

<style>
@font-face {
  font-family: 'Stellar';
  src: url('https://cdn.shopify.com/s/files/1/1000/9375/5727/files/MirageStellar.ttf?v=1772405200') format('opentype');
  font-display: swap;
}

.rituel-teaser {
  position: relative;
  overflow: hidden;
  background: #1E2244;
  color: #ffffff;
  padding-block-start: 80px;
  padding-block-end: 80px;
}

/* Fond étoilé */
.rituel-teaser__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}
.rituel-teaser__moon-glow {
  position: absolute;
  top: -80px;
  left: 50%;
  transform: translateX(-50%);
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(200,184,154,0.18) 0%, transparent 70%);
  border-radius: 50%;
}
.rituel-teaser__stars,
.rituel-teaser__stars-2 {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(1px 1px at 30% 60%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 50% 15%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 70% 40%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 85% 70%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 20% 80%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 60% 85%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 90% 10%, rgba(255,255,255,0.6) 0%, transparent 100%);
}
.rituel-teaser__stars-2 {
  background-image:
    radial-gradient(1px 1px at 15% 45%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 40% 30%, rgba(255,255,255,0.5) 0%, transparent 100%),
    radial-gradient(1px 1px at 65% 55%, rgba(255,255,255,0.4) 0%, transparent 100%),
    radial-gradient(1px 1px at 80% 25%, rgba(255,255,255,0.3) 0%, transparent 100%),
    radial-gradient(1px 1px at 5% 65%, rgba(255,255,255,0.6) 0%, transparent 100%),
    radial-gradient(1px 1px at 55% 75%, rgba(255,255,255,0.4) 0%, transparent 100%);
}

/* Contenu */
.rituel-teaser__inner {
  position: relative;
  z-index: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.rituel-teaser__badge {
  font-family: 'Raleway', sans-serif;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C8B89A;
  border: 1px solid rgba(200,184,154,0.4);
  padding: 6px 16px;
  border-radius: 20px;
}

.rituel-teaser__title {
  font-family: 'Stellar', serif;
  font-size: clamp(1.8rem, 4.5vw, 3rem);
  font-weight: 400;
  letter-spacing: 0.06em;
  color: #ffffff;
  margin: 0;
  line-height: 1.2;
}

.rituel-teaser__subtitle {
  font-family: 'Raleway', sans-serif;
  font-size: 0.95rem;
  font-weight: 400;
  line-height: 1.8;
  opacity: 0.75;
  max-width: 560px;
  margin: 0;
}

.rituel-teaser__sounds {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  margin-top: 8px;
}

.rituel-teaser__sound-item {
  font-family: 'Raleway', sans-serif;
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 30px;
  padding: 8px 18px;
  font-size: 0.88rem;
  letter-spacing: 0.02em;
}

.rituel-teaser__sound-icon {
  font-size: 1rem;
}

/* CTA */
.rituel-teaser__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 8px;
  padding: var(--button-padding-block, 16px) var(--button-padding-inline, 24px);
  background: var(--color-primary-button-background, #ffffff);
  color: var(--color-primary-button-text, #191a2e);
  border: var(--style-border-width-primary, 0px) solid var(--color-primary-button-border, #ffffff);
  border-radius: var(--style-border-radius-buttons-primary, 16px);
  font-family: var(--button-font-family-primary, 'Raleway', sans-serif);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
  box-shadow: var(--shadow-button, none);
}
.rituel-teaser__cta:hover {
  background: var(--color-primary-button-hover-background, #191a2e);
  color: var(--color-primary-button-hover-text, #ffffff);
  border-color: var(--color-primary-button-hover-border, #191a2e);
}

.rituel-teaser__mention {
  font-family: 'Raleway', sans-serif;
  font-size: 0.78rem;
  opacity: 0.4;
  letter-spacing: 0.05em;
  margin: 0;
}

@media (max-width: 640px) {
  .rituel-teaser { padding-block-start: 56px; padding-block-end: 56px; }
  .rituel-teaser__sounds { gap: 8px; }
  .rituel-teaser__sound-item { font-size: 0.82rem; padding: 7px 14px; }
}
</style>

{% schema %}
{
  "name": "Rituel sonore — teaser",
  "settings": [],
  "presets": [{"name": "Rituel sonore — teaser"}]
}
{% endschema %}