    outline: none;
    transition: height 0.2s ease;
  }

  .moona-rituel__progress-track:hover {
    height: 6px;
  }

  .moona-rituel__progress-track:focus-visible {
    box-shadow: 0 0 0 3px rgba(255,255,255,0.25);
  }

  .moona-rituel__progress-fill {
    height: 100%;
    background: #C8B89A;
    border-radius: 4px;
    width: 0%;
    pointer-events: none;
