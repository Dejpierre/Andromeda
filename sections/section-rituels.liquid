  /* ── Sleep timer ────────────────────────────────────── */
  .moona-rituel__sleep {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .moona-rituel__sleep-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    padding: 4px 10px;
    border-radius: 20px;
    transition: background 0.15s, color 0.15s;
  }

  .moona-rituel__sleep-btn:hover {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.55);
  }

  .moona-rituel__sleep-btn--active {
    color: #C8B89A;
    background: rgba(200,184,154,0.1);
    font-weight: 500;
  }

  .moona-rituel__sleep-opts {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .moona-rituel__sleep-opt {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .moona-rituel__sleep-opt:hover {
    background: rgba(255,255,255,0.12);
    color: #FFFFFF;
    border-color: rgba(255,255,255,0.25);
  }

  /* ── Footer ─────────────────────────────────────────── */
  .moona-rituel__footer {
    text-align: center;
  }

  .moona-rituel__shop-link {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
