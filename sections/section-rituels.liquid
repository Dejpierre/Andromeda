<div class="moona-rituel" id="moona-rituel">

  <!-- Fond nuit -->
  <div class="moona-rituel__bg" aria-hidden="true">
    <div class="moona-rituel__moon-glow"></div>
    <div class="moona-rituel__stars"></div>
    <div class="moona-rituel__stars-2"></div>
  </div>

  <div class="moona-rituel__wrap">

    <div class="moona-rituel__greeting moona-anim-1" id="moona-greeting">
      {%- if section.settings.title != blank -%}
        <h1 class="moona-rituel__title">{{ section.settings.title }}</h1>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="moona-rituel__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <!-- État : pas de token -->
    <div class="moona-rituel__error moona-anim-3" id="moona-no-token" hidden>
      <div class="moona-rituel__error-icon">✦</div>
      <p>{{ section.settings.no_token_msg | default: 'Scanne le QR code sur ton packaging pour accéder à tes rituels.' }}</p>
    </div>

    <!-- État : token invalide -->
    <div class="moona-rituel__error moona-anim-3" id="moona-invalid" hidden>
      <div class="moona-rituel__error-icon">✦</div>
      <p>{{ section.settings.invalid_msg | default: "Ce lien n'est pas valide ou a expiré. Contacte-nous si tu as besoin d'aide." }}</p>
    </div>

    <!-- Sélecteur de catégorie -->
    <div class="moona-rituel__moments" id="moona-moments" hidden>

      <button class="moona-rituel__moment moona-anim-3" data-category="sommeil" type="button">
        <div class="moona-rituel__moment-bg moona-rituel__moment-bg--sommeil"></div>
        <div class="moona-rituel__moment-inner">
          <span class="moona-rituel__moment-label">{{ section.settings.label_sommeil | default: "Ambiance pour s'endormir" }}</span>
          <span class="moona-rituel__moment-desc">{{ section.settings.desc_sommeil | default: "Sons apaisants pour glisser vers le sommeil" }}</span>
        </div>
      </button>

      <button class="moona-rituel__moment moona-anim-4" data-category="meditation" type="button">
        <div class="moona-rituel__moment-bg moona-rituel__moment-bg--sommeil"></div>
        <div class="moona-rituel__moment-inner">
          <span class="moona-rituel__moment-label">{{ section.settings.label_meditation | default: "Méditation guidée" }}</span>
          <span class="moona-rituel__moment-desc">{{ section.settings.desc_meditation | default: "Une voix douce pour te recentrer" }}</span>
        </div>
      </button>

      <button class="moona-rituel__moment moona-anim-5" data-category="nature" type="button">
        <div class="moona-rituel__moment-bg moona-rituel__moment-bg--sommeil"></div>
        <div class="moona-rituel__moment-inner">
          <span class="moona-rituel__moment-label">{{ section.settings.label_nature | default: "Sons de la nature" }}</span>
          <span class="moona-rituel__moment-desc">{{ section.settings.desc_nature | default: "Pluie, forêt, océan…" }}</span>
        </div>
      </button>

    </div>

    <!-- Player immersif -->
    <div class="moona-rituel__player-wrap" id="moona-player-wrap" hidden>

      <div class="moona-rituel__player-header">
        <button class="moona-rituel__back-btn" id="moona-back-btn" type="button">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {{ section.settings.back_to_moments | default: 'Choisir un autre rituel' }}
        </button>
        <span class="moona-rituel__player-moment" id="moona-player-moment"></span>
        <button class="moona-rituel__offline-btn" id="moona-offline-btn" type="button" aria-label="Sauvegarder hors-ligne" hidden>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="moona-offline-icon-dl" aria-hidden="true">
            <path d="M12 3v12M7 11l5 5 5-5"/><path d="M4 19h16"/>
          </svg>
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="moona-offline-icon-ok" aria-hidden="true" hidden>
            <path d="M20 6L9 17l-5-5"/>
          </svg>
        </button>
      </div>

      <!-- Loader -->
      <div class="moona-rituel__loader" id="moona-loader" aria-label="Chargement…" hidden>
        <span></span><span></span><span></span>
      </div>

      <!-- Player custom -->
      <div class="moona-rituel__player" id="moona-player" hidden>
        <div class="moona-rituel__orb-wrap" aria-hidden="true">
          <canvas id="moona-orb-canvas" width="560" height="560"></canvas>
        </div>

        <div class="moona-rituel__controls">
          <button class="moona-rituel__seek-btn" id="moona-rewind" type="button" aria-label="Reculer 15s">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M12 5V2L7 7l5 5V8c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z" fill="currentColor"/>
              <text x="12" y="14.5" text-anchor="middle" font-size="5.5" fill="currentColor" font-family="sans-serif">15</text>
            </svg>
          </button>

          <button class="moona-rituel__play-btn" id="moona-play-btn" type="button" aria-label="Lecture">
            <svg class="moona-rituel__icon-play" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg class="moona-rituel__icon-pause" width="26" height="26" viewBox="0 0 24 24" fill="currentColor" hidden>
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>

          <button class="moona-rituel__seek-btn" id="moona-forward" type="button" aria-label="Avancer 15s">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M12 5V2l5 5-5 5V8c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6h2c0 4.42-3.58 8-8 8s-8-3.58-8-8 3.58-8 8-8z" fill="currentColor"/>
              <text x="12" y="14.5" text-anchor="middle" font-size="5.5" fill="currentColor" font-family="sans-serif">15</text>
            </svg>
          </button>
        </div>

        <div class="moona-rituel__progress-wrap">
          <span class="moona-rituel__time" id="moona-current">0:00</span>
          <div class="moona-rituel__progress-track" id="moona-track" role="slider" aria-label="Progression" tabindex="0">
            <div class="moona-rituel__progress-fill" id="moona-fill"></div>
            <div class="moona-rituel__progress-thumb" id="moona-thumb"></div>
          </div>
          <span class="moona-rituel__time" id="moona-duration">—</span>
        </div>

        <div class="moona-rituel__sleep">
          <button class="moona-rituel__sleep-btn" id="moona-sleep-btn" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
            </svg>
            <span id="moona-sleep-label">Minuterie</span>
          </button>
          <div class="moona-rituel__sleep-opts" id="moona-sleep-opts" hidden>
            <button class="moona-rituel__sleep-opt" data-min="15" type="button">15 min</button>
            <button class="moona-rituel__sleep-opt" data-min="30" type="button">30 min</button>
            <button class="moona-rituel__sleep-opt" data-min="45" type="button">45 min</button>
            <button class="moona-rituel__sleep-opt" data-min="60" type="button">60 min</button>
          </div>
        </div>
      </div>

      <audio id="moona-audio" preload="metadata"></audio>
    </div>

    {%- if section.settings.show_back_link -%}
      <div class="moona-rituel__footer moona-anim-6">
        <a href="{{ section.settings.back_url | default: '/' }}" class="moona-rituel__shop-link">
          {{ section.settings.back_label | default: '← Retour à la boutique' }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  @font-face {
    font-family: 'Stellar';
    src: url('https://cdn.shopify.com/s/files/1/1000/9375/5727/files/MirageStellar.ttf?v=1772405200') format('opentype');
    font-display: swap;
  }

  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes moona-fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes moona-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes moona-slide-in {
    from { opacity: 0; transform: translateY(32px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes moona-slide-out {
    from { opacity: 1; transform: translateY(0) scale(1); }
    to   { opacity: 0; transform: translateY(-20px) scale(0.97); }
  }

  @keyframes moona-breathe {
    0%, 100% { opacity: 0.6; transform: translate(-50%, -55%) scale(1); }
    50%       { opacity: 1;   transform: translate(-50%, -55%) scale(1.1); }
  }

  @keyframes moona-stars-twinkle {
    0%, 100% { opacity: 0.5; }
    50%       { opacity: 0.9; }
  }

  @keyframes moona-stars-drift-1 {
    0%, 100% { transform: translate(0, 0); }
    30%       { transform: translate(-10px, -8px); }
    65%       { transform: translate(7px, -13px); }
  }

  @keyframes moona-stars-drift-2 {
    0%, 100% { transform: translate(0, 0); }
    40%       { transform: translate(12px, -7px); }
    70%       { transform: translate(-6px, 10px); }
  }

  @keyframes moona-orb-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(40px, -30px) scale(1.08); }
    66%       { transform: translate(-20px, 20px) scale(0.95); }
  }

  @keyframes moona-orb-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40%       { transform: translate(-50px, 30px) scale(1.1); }
    70%       { transform: translate(30px, -10px) scale(0.92); }
  }

  @keyframes moona-orb-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(20px, 40px) scale(1.06); }
  }

  @keyframes moona-orb-4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    45%       { transform: translate(-35px, -45px) scale(1.08); }
    75%       { transform: translate(28px, 22px) scale(0.94); }
  }

  @keyframes moona-stars-pulse {
    0%, 100% { opacity: 0.55; }
    50%       { opacity: 0.85; }
  }

  @keyframes moona-bounce {
    0%, 80%, 100% { transform: scale(0.5); opacity: 0.3; }
    40%           { transform: scale(1.1); opacity: 1; }
  }


  /* ── Entrance animations ────────────────────────────── */
  .moona-anim-1 { animation: moona-fade-up 0.6s cubic-bezier(.22,1,.36,1) both; animation-delay: 0.05s; }
  .moona-anim-2 { animation: moona-fade-up 0.6s cubic-bezier(.22,1,.36,1) both; animation-delay: 0.18s; }
  .moona-anim-3 { animation: moona-fade-up 0.6s cubic-bezier(.22,1,.36,1) both; animation-delay: 0.32s; }
  .moona-anim-4 { animation: moona-fade-up 0.6s cubic-bezier(.22,1,.36,1) both; animation-delay: 0.44s; }
  .moona-anim-5 { animation: moona-fade-up 0.6s cubic-bezier(.22,1,.36,1) both; animation-delay: 0.56s; }
  .moona-anim-6 { animation: moona-fade-in 0.7s ease both; animation-delay: 0.7s; }

  /* Forcer display:none sur les éléments cachés */
  #moona-rituel [hidden] { display: none !important; animation: none !important; }

  /* Transition states gérées par JS */
  .moona-is-entering {
    animation: moona-slide-in 0.45s cubic-bezier(.22,1,.36,1) both !important;
  }

  .moona-is-leaving {
    animation: moona-slide-out 0.3s ease forwards !important;
    pointer-events: none;
  }

  /* ── Base ───────────────────────────────────────────── */
  .moona-rituel {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px 60px;
    font-family: inherit;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* ── Background animé ───────────────────────────────── */
  .moona-rituel__bg {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at 50% 30%, #1E2244 0%, #191A2E 65%);
    z-index: -1;
  }

  .moona-rituel__moon-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(210,205,190,0.055) 0%, transparent 70%);
    top: 55%;
    left: 50%;
    transform: translate(-50%, -55%);
    animation: moona-breathe 9s ease-in-out infinite;
    pointer-events: none;
  }

  .moona-rituel__stars,
  .moona-rituel__stars-2 {
    position: absolute;
    inset: -20px;
    pointer-events: none;
  }

  .moona-rituel__stars {
    background-image:
      radial-gradient(1px 1px at 12% 9%,   rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 27% 5%,  rgba(255,255,255,0.4)  0%, transparent 100%),
      radial-gradient(1px 1px at 44% 14%,  rgba(255,255,255,0.5)  0%, transparent 100%),
      radial-gradient(2px 2px at 63% 6%,   rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 80% 11%,  rgba(255,255,255,0.5)  0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 92% 20%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 6%  32%,  rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(2px 2px at 19% 40%,  rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1px 1px at 36% 28%,  rgba(255,255,255,0.3)  0%, transparent 100%),
      radial-gradient(1px 1px at 51% 22%,  rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 74% 18%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 30%,  rgba(255,255,255,0.3)  0%, transparent 100%),
      radial-gradient(1px 1px at 8%  50%,  rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(2px 2px at 42% 47%,  rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 67% 52%,  rgba(255,255,255,0.4)  0%, transparent 100%);
    animation: moona-stars-twinkle 14s ease-in-out infinite,
               moona-stars-drift-1 22s ease-in-out infinite;
  }

  .moona-rituel__stars-2 {
    background-image:
      radial-gradient(1px 1px at 72% 35%,  rgba(255,255,255,0.4)  0%, transparent 100%),
      radial-gradient(1px 1px at 88% 42%,  rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 4%  62%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1px 1px at 33% 72%,  rgba(255,255,255,0.3)  0%, transparent 100%),
      radial-gradient(2px 2px at 55% 68%,  rgba(255,255,255,0.4)  0%, transparent 100%),
      radial-gradient(1px 1px at 78% 75%,  rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 94% 60%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1px 1px at 16% 80%,  rgba(255,255,255,0.3)  0%, transparent 100%),
      radial-gradient(1px 1px at 48% 85%,  rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(2px 2px at 62% 78%,  rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 82%,  rgba(255,255,255,0.4)  0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 22% 58%, rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 38% 90%,  rgba(255,255,255,0.3)  0%, transparent 100%),
      radial-gradient(1px 1px at 70% 92%,  rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 56% 44%,  rgba(255,255,255,0.3)  0%, transparent 100%);
    animation: moona-stars-twinkle 18s ease-in-out infinite 3s,
               moona-stars-drift-2 30s ease-in-out infinite;
  }


  .moona-rituel__wrap {
    width: 100%;
    max-width: 580px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  /* ── Logo ───────────────────────────────────────────── */
  .moona-rituel__logo {
    opacity: 0.85;
  }

  .moona-rituel__logo img {
    height: 40px;
    width: auto;
    display: block;
  }

  .moona-rituel__logo--text {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #FFFFFF;
    text-transform: uppercase;
  }

  /* ── Greeting ───────────────────────────────────────── */
  .moona-rituel__greeting {
    text-align: center;
  }

  .moona-rituel__title {
    font-size: clamp(24px, 5vw, 36px);
    font-family: 'Stellar', serif !important;
    font-weight: 400;
    color: #FFFFFF;
    margin: 0 0 10px;
    line-height: 1.25;
    letter-spacing: 0;
    word-spacing: -0.22em;
  }

  .moona-rituel__subtitle {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Error states ───────────────────────────────────── */
  .moona-rituel__error {
    text-align: center;
    padding: 32px 24px;
    background: rgba(255,255,255,0.06);
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    width: 100%;
  }

  .moona-rituel__error-icon {
    font-size: 24px;
    color: #C8B89A;
    margin-bottom: 12px;
  }

  .moona-rituel__error p {
    color: rgba(255,255,255,0.55);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Moment cards ───────────────────────────────────── */
  .moona-rituel__moments {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
  }

  .moona-rituel__moment {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0;
    border: none;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    background: transparent;
    text-align: left;
    transition: transform 0.22s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s ease;
    box-shadow: 0 2px 16px rgba(0,0,0,0.25);
    -webkit-tap-highlight-color: transparent;
  }

  .moona-rituel__moment:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.15);
  }

  .moona-rituel__moment:active {
    transform: scale(0.98);
  }

  .moona-rituel__moment-bg {
    position: absolute;
    inset: 0;
    transition: opacity 0.3s ease;
  }

  .moona-rituel__moment:hover .moona-rituel__moment-bg {
    opacity: 0.85;
  }

  .moona-rituel__moment-bg--sommeil {
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.12);
  }

  .moona-rituel__moment-inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 22px 24px;
    width: 100%;
  }

  .moona-rituel__moment-emoji {
    font-size: 32px;
    line-height: 1;
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
  }

  .moona-rituel__moment:hover .moona-rituel__moment-emoji {
    transform: scale(1.15) rotate(-5deg);
  }

  .moona-rituel__moment-label {
    font-size: 17px;
    font-weight: 500;
    color: #FFFFFF;
    display: block;
    letter-spacing: 0.01em;
  }

  .moona-rituel__moment-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    display: block;
    margin-top: 3px;
    line-height: 1.4;
  }

  .moona-rituel__moment-inner > div {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  /* Arrow indicator */
  .moona-rituel__moment-inner::after {
    content: '→';
    color: #C8B89A;
    font-size: 18px;
    margin-left: auto;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .moona-rituel__moment:hover .moona-rituel__moment-inner::after {
    transform: translateX(4px);
  }

  /* ── Player wrap ────────────────────────────────────── */
  .moona-rituel__player-wrap {
    width: 100%;
    background: rgba(255,255,255,0.06);
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(12px);
    padding: 28px 28px 32px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.25);
  }

  .moona-rituel__player-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .moona-rituel__back-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
