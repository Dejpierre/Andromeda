  }

  .moona-rituel__progress-thumb {
    position: absolute;
    top: 50%;
    left: 0%;
    transform: translate(-50%, -50%);
    width: 14px;
    height: 14px;
    background: #FFFFFF;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, left 0.1s linear, transform 0.15s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }

  .moona-rituel__progress-track:hover .moona-rituel__progress-thumb,
  .moona-rituel__progress-track:focus-visible .moona-rituel__progress-thumb {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.2);
  }

  /* ── Offline button ─────────────────────────────────── */
  .moona-rituel__offline-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    border: none;
    cursor: pointer;
    color: rgba(255,255,255,0.4);
    transition: background 0.15s, color 0.15s, transform 0.18s ease;
    flex-shrink: 0;
  }

  .moona-rituel__offline-btn:hover {
    background: rgba(255,255,255,0.15);
    color: #FFFFFF;
    transform: scale(1.1);
  }

  .moona-rituel__offline-btn--cached {
    color: #34d399;
